<Window x:Class="UltraVideoEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:UltraVideoEditor"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
        xmlns:wfhost="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        Title="ULTRA VIDEO EDITOR v1.0" Height="950" Width="1400" 
        Background="#0A0A0A"
        WindowStartupLocation="CenterScreen"
        Focusable="True">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Margin="0,0,0,5" Background="#1E1E1E" Foreground="White" AutomationProperties.Name="Glavni meni">
            <MenuItem Header="_Datoteka">
                <MenuItem Header="_Novi projekat" InputGestureText="Ctrl+N" Click="NewProject_Click"/>
                <MenuItem Header="_Otvori projekat..." InputGestureText="Ctrl+O" Click="LoadProject_Click"/>
                <Separator/>
                <MenuItem Header="_Sačuvaj projekat" InputGestureText="Ctrl+S" Click="SaveProject_Click"/>
                <MenuItem Header="Sačuvaj _kao..." InputGestureText="F12" Click="SaveAsProject_Click"/>
                <Separator/>
                <MenuItem Header="_Izvezi video..." InputGestureText="Ctrl+E" Click="FinalRender_Click"/>
                <MenuItem Header="_Opcije izvoza..." Click="ShowExportOptions_Click"/>
                <MenuItem Header="📱 Izvezi za Shorts/TikTok/Instagram..." Click="ExportMultiFormat_Click"/>
                <Separator/>
                <MenuItem Header="I_zlaz" InputGestureText="Alt+F4" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Uredi">
                <MenuItem Header="_Poništi" InputGestureText="Ctrl+Z" Click="Undo_Click"/>
                <MenuItem Header="_Ponovi" InputGestureText="Ctrl+Y" Click="Redo_Click"/>
                <Separator/>
                <MenuItem Header="I_seci" InputGestureText="Ctrl+X" Click="CutClip_Click"/>
                <MenuItem Header="_Kopiraj" InputGestureText="Ctrl+C" Click="CopyClip_Click"/>
                <MenuItem Header="_Zalepi" InputGestureText="Ctrl+V" Click="PasteClip_Click"/>
                <Separator/>
                <MenuItem Header="Iseci na _svim markerima" InputGestureText="Ctrl+Shift+X" Click="CutAtAllMarkers_Click"/>
                <Separator/>
                <MenuItem Header="_Obriši selektovano" InputGestureText="Del" Click="RemoveFromTimeline_Click"/>
                <Separator/>
                <MenuItem Header="Izaberi _sve" InputGestureText="Ctrl+A" Click="SelectAll_Click"/>
            </MenuItem>
            <MenuItem Header="_Prikaz">
                <MenuItem Header="Uvećaj _zoom" InputGestureText="Ctrl++" Click="ZoomIn_Click"/>
                <MenuItem Header="Umanji _zoom" InputGestureText="Ctrl+-" Click="ZoomOut_Click"/>
                <MenuItem Header="_Resetuj zoom" InputGestureText="Ctrl+0" Click="ResetZoom_Click"/>
                <Separator/>
                <MenuItem Header="Prikaži _sve trake" Click="ShowAllTracks_Click"/>
                <MenuItem Header="Prikaži samo _video trake" Click="ShowVideoTracksOnly_Click"/>
                <MenuItem Header="Prikaži samo _audio trake" Click="ShowAudioTracksOnly_Click"/>
                <Separator/>
                <MenuItem Header="_Pristupačni mod" InputGestureText="Ctrl+Shift+A" Click="ToggleAccessibilityMode_Click"/>
                <MenuItem Header="_Log prozor" InputGestureText="Ctrl+Shift+L" Click="ShowLogWindow_Click"/>
                <Separator/>
                <MenuItem Header="_Jezik">
                    <MenuItem Header="Srpski" Click="SetLanguageSerbian_Click"/>
                    <MenuItem Header="English" Click="SetLanguageEnglish_Click"/>
                    <MenuItem Header="Deutsch" Click="SetLanguageGerman_Click"/>
                </MenuItem>
                <MenuItem Header="_Tema">
                    <MenuItem Header="🌙 Tamna (default)" Click="SetThemeDark_Click"/>
                    <MenuItem Header="⚡ Visoki kontrast" Click="SetThemeContrast_Click"/>
                    <MenuItem Header="☀️ Svetla" Click="SetThemeLight_Click"/>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="_Vremenska traka">
                <MenuItem Header="Dodaj _video/sliku..." InputGestureText="Ctrl+I" Click="AddVideoImage_Click"/>
                <MenuItem Header="Dodaj _audio..." InputGestureText="Ctrl+Shift+I" Click="AddAudioOnly_Click"/>
                <Separator/>
                <MenuItem Header="Dodaj _video traku" Click="AddVideoTrack_Click"/>
                <MenuItem Header="Dodaj _audio traku" Click="AddAudioTrack_Click"/>
                <Separator/>
                <MenuItem Header="Pomeri klip _levo" InputGestureText="Ctrl+Left" Click="MoveLeft_Click"/>
                <MenuItem Header="Pomeri klip _desno" InputGestureText="Ctrl+Right" Click="MoveRight_Click"/>
                <MenuItem Header="Pomeri klip _gore" InputGestureText="Ctrl+Up" Click="MoveClipUp_Click"/>
                <MenuItem Header="Pomeri klip _dole" InputGestureText="Ctrl+Down" Click="MoveClipDown_Click"/>
                <Separator/>
                <MenuItem Header="Podesi _trajanje klipa..." InputGestureText="Ctrl+D" Click="SetClipDuration_Click"/>
                <MenuItem Header="Podesi _jačinu zvuka..." InputGestureText="Ctrl+Alt+V" Click="SetClipVolume_Click"/>
                <Separator/>
                <MenuItem Header="Dodaj _marker" InputGestureText="Ctrl+M" Click="AddMarker_Click"/>
                <MenuItem Header="_Sledeći marker" InputGestureText="Ctrl+Shift+N" Click="NextMarker_Click"/>
                <MenuItem Header="_Prethodni marker" InputGestureText="Ctrl+Shift+P" Click="PrevMarker_Click"/>
                <MenuItem Header="Obriši _sve markere" Click="ClearAllMarkers_Click"/>
            </MenuItem>
            <MenuItem Header="_Veštačka inteligencija">
                <MenuItem Header="🎬 Video Engine (AUTO)" Click="OpenVideoEngine_Click" FontWeight="Bold"/>
                <MenuItem Header="👁 Opisi klipova (Vision AI)..." Click="DescribeAllClips_Click"/>
                <Separator/>
                <MenuItem Header="_Generiši glas..." Click="GenerateVoice_Click"/>
                <MenuItem Header="Generiši _kadrove..." Click="GenerateAI_Click"/>
                <MenuItem Header="_Transkribuj audio..." Click="TranscribeAudio_Click"/>
                <MenuItem Header="_Sinhronizuj tekst..." Click="SyncLyrics_Click"/>
                <MenuItem Header="Dodaj _sinhronizovane titlove" Click="AddSyncedSubtitles_Click"/>
            </MenuItem>
            <MenuItem Header="_Efekti">
                <MenuItem Header="_Video efekti" Click="ShowVideoEffectsTab_Click"/>
                <MenuItem Header="_Audio efekti" Click="ShowAudioEffectsTab_Click"/>
                <MenuItem Header="_Tranzicije" Click="ShowTransitionsTab_Click"/>
                <MenuItem Header="_Animacije (Keyframe)" Click="ShowAnimationTab_Click"/>
                <Separator/>
                <MenuItem Header="Primeni _efekte na selektovano" InputGestureText="Ctrl+Shift+E" Click="ApplyEffects_Click"/>
                <MenuItem Header="_Resetuj efekte na selektovanom" Click="ResetEffects_Click"/>
            </MenuItem>
            <MenuItem Header="_Alati">
                <MenuItem Header="_Titlovi" Click="ShowSubtitlesTab_Click"/>
                <MenuItem Header="_Markeri" Click="ShowMarkersDialog_Click"/>
                <Separator/>
                <MenuItem Header="_GPU ubrzanje" IsCheckable="True" IsChecked="True" Click="ToggleGPUAcceleration_Click"/>
                <MenuItem Header="_Postavke..." Click="ShowPreferences_Click"/>
            </MenuItem>
            <MenuItem Header="_Pomoć">
                <MenuItem Header="_Tastaturne prečice" InputGestureText="F1" Click="ShowHelp_Click"/>
                <MenuItem Header="_Korisničko uputstvo" Click="ShowUserManual_Click"/>
                <Separator/>
                <MenuItem Header="Provera _ažuriranja" Click="CheckForUpdates_Click"/>
                <Separator/>
                <MenuItem Header="_O programu" Click="ShowAbout_Click"/>
            </MenuItem>
        </Menu>

        <ToolBar Grid.Row="1" Margin="0,0,0,10" Background="#1E1E1E">
            <Button x:Name="btnNew" Content="📄 Novi" Click="NewProject_Click" ToolTip="Novi projekat (Ctrl+N)"/>
            <Button x:Name="btnOpen" Content="📂 Otvori" Click="LoadProject_Click" ToolTip="Otvori projekat (Ctrl+O)"/>
            <Button x:Name="btnSave" Content="💾 Sačuvaj" Click="SaveProject_Click" ToolTip="Sačuvaj projekat (Ctrl+S)"/>
            <Button x:Name="btnPixabay" Content="🔍 PIXABAY" Click="btnPixabay_Click" 
        Background="#4A148C" Foreground="White" ToolTip="Pretraži i preuzmi slike sa Pixabay-a (besplatno)"/>
            <Button x:Name="btnAIVideoCreator" Content="🤖 AI VIDEO" Click="btnAIVideoCreator_Click" 
        Background="#9C27B0" Foreground="White" ToolTip="AI Video Creator - automatsko kreiranje videa iz teksta pjesme"/>
            <Separator/>
            <Button x:Name="btnUndoTool" Content="↩️ Poništi" Click="Undo_Click" ToolTip="Poništi (Ctrl+Z)"/>
            <Button x:Name="btnRedoTool" Content="↪️ Ponovi" Click="Redo_Click" ToolTip="Ponovi (Ctrl+Y)"/>
            <Separator/>
            <Button x:Name="btnCutTool" Content="✂ Seci" Click="CutClip_Click" ToolTip="Seci (Ctrl+X)"/>
            <Button x:Name="btnCopyTool" Content="📋 Kopiraj" Click="CopyClip_Click" ToolTip="Kopiraj (Ctrl+C)"/>
            <Button x:Name="btnPasteTool" Content="📌 Zalepi" Click="PasteClip_Click" ToolTip="Zalepi (Ctrl+V)"/>
            <Separator/>
            <Button x:Name="btnDeleteTool" Content="🗑 Obriši" Click="RemoveFromTimeline_Click" ToolTip="Obriši (Del)"/>
            <Separator/>
            <Button x:Name="btnAccessibilityTool" Content="♿ Pristupačnost" Click="ToggleAccessibilityMode_Click" ToolTip="Pristupačni mod (Ctrl+Shift+A)"/>
            <Button x:Name="btnLogTool" Content="📋 Log" Click="ShowLogWindow_Click" ToolTip="Log prozor (Ctrl+Shift+L)"/>
            <Separator/>
            <Button x:Name="btnRenderTool" Content="🎬 RENDER" Click="FinalRender_Click" ToolTip="Renderuj projekat (Ctrl+R)" Background="#B71C1C" Foreground="White"/>
            <Button x:Name="btnAutoArrange" Content="🎬 AUTO-RASPOREDI" Click="btnAutoArrange_Click" 
        Background="#FF6F00" Foreground="White" ToolTip="Automatski rasporedi slike sa efektima"/>
            <Button x:Name="btnTestFix" Content="🔧 TEST FIX" Click="btnTestFix_Click" Background="Orange" Foreground="White"/>
            <Button x:Name="btnTest" Content="🔧 TEST" Click="TestButton_Click" Background="#FF6F00" Foreground="White" ToolTip="Test dugme"/>
        </ToolBar>

        <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="5" Margin="0,0,0,10" 
                x:Name="borderAccessibilityStatus" Visibility="Collapsed">
            <TextBlock x:Name="txtAccessibilityStatus" Foreground="#00E676" 
                       Text="♿ PRISTUPACNI MOD UKLJUCEN"
                       Padding="10" FontWeight="Bold" TextAlignment="Center"/>
        </Border>

        <Border Grid.Row="3" Background="Black" Height="200" CornerRadius="5" 
                BorderBrush="#444" BorderThickness="1" Margin="0,0,0,10">
            <vlc:VideoView x:Name="vlcVideoView"/>
        </Border>

        <TabControl Grid.Row="3" Margin="0,210,0,0" Background="#121212" BorderBrush="#333">

            <TabItem x:Name="tabTimeline" Header="📋 TIMELINE">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
                        <Button x:Name="btnMoveLeft" Content="⬅ POMERI LEVO (Ctrl+Left)" Click="MoveLeft_Click" Width="150" Height="32" Background="#4A148C" Foreground="White"/>
                        <Button x:Name="btnMoveRight" Content="➡ POMERI DESNO (Ctrl+Right)" Click="MoveRight_Click" Width="160" Height="32" Background="#4A148C" Foreground="White" Margin="5,0"/>
                        <Button x:Name="btnCut" Content="✂ SECI (Ctrl+X)" Click="CutClip_Click" Width="120" Height="32" Background="#FF6F00" Foreground="White" Margin="5,0"/>
                        <Button x:Name="btnCutAllMarkers" Content="✂✂ SECI SVE MARKERE (Ctrl+Shift+X)" Click="CutAtAllMarkers_Click" Width="180" Height="32" Background="#FF6F00" Foreground="White" Margin="5,0"/>
                        <Button x:Name="btnDuration" Content="⏱ TRAJANJE (Ctrl+D)" Click="SetClipDuration_Click" Width="130" Height="32" Background="#FF9800" Foreground="White" Margin="5,0"/>
                        <Button x:Name="btnVolume" Content="🔊 JACINA ZVUKA" Click="SetClipVolume_Click" Width="120" Height="32" Background="#FF9800" Foreground="White" Margin="5,0"/>
                        <Separator Width="15" Background="#333" Margin="5,0"/>
                        <Button x:Name="btnZoomIn" Content="🔍 ZOOM + (Ctrl++)" Click="ZoomIn_Click" Width="120" Height="32" Background="#4A148C" Foreground="White"/>
                        <Button x:Name="btnZoomOut" Content="ZOOM - (Ctrl+-)" Click="ZoomOut_Click" Width="100" Height="32" Background="#4A148C" Foreground="White" Margin="5,0"/>
                        <TextBlock x:Name="txtZoomStatus" Text="Zoom: 1.0x" Foreground="Yellow" VerticalAlignment="Center" Margin="10,0" FontSize="11"/>
                        <Separator Width="15" Background="#333" Margin="5,0"/>
                        <Button x:Name="btnAddMarker" Content="📍 MARKER (Ctrl+M)" Click="AddMarker_Click" Width="130" Height="32" Background="#2E7D32" Foreground="White"/>
                        <Button x:Name="btnNextMarker" Content="⏩ SLEDECI (Ctrl+Shift+N)" Click="NextMarker_Click" Width="140" Height="32" Background="#2E7D32" Foreground="White" Margin="5,0"/>
                        <Button x:Name="btnPrevMarker" Content="⏪ PRETHODNI (Ctrl+Shift+P)" Click="PrevMarker_Click" Width="140" Height="32" Background="#2E7D32" Foreground="White"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock x:Name="txtTrackSelector" Text="Prikaži traku:" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="cmbTrackSelector" Width="120" Height="25" SelectionChanged="TrackSelector_Changed" Background="#333" Foreground="White">
                            <ComboBoxItem Content="🎬 Video 1" Tag="0" IsSelected="True"/>
                            <ComboBoxItem Content="🎬 Video 2" Tag="1"/>
                            <ComboBoxItem Content="🎵 Audio 1" Tag="2"/>
                            <ComboBoxItem Content="🎵 Audio 2" Tag="3"/>
                            <ComboBoxItem Content="📋 Sve trake" Tag="-1"/>
                        </ComboBox>
                    </StackPanel>

                    <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="5" BorderBrush="#333" BorderThickness="1">
                        <wfhost:WindowsFormsHost x:Name="wfhTimeline" Margin="2">
                            <wf:ListView x:Name="timelineListView" 
                                         View="Details"
                                         FullRowSelect="True"
                                         GridLines="False"
                                         HideSelection="False"
                                         MultiSelect="True"
                                         AutoArrange="True"
                                         BackColor="#1E1E1E"
                                         ForeColor="White"
                                         Font="Segoe UI, 10pt">
                                <wf:ListView.Columns>
                                    <wf:ColumnHeader Text="Br." Width="50" TextAlign="Center"/>
                                    <wf:ColumnHeader Text="Ime klipa" Width="350"/>
                                    <wf:ColumnHeader Text="Tip" Width="60"/>
                                    <wf:ColumnHeader Text="Trajanje" Width="80" TextAlign="Center"/>
                                    <wf:ColumnHeader Text="Početak" Width="80" TextAlign="Center"/>
                                    <wf:ColumnHeader Text="Kraj" Width="80" TextAlign="Center"/>
                                    <wf:ColumnHeader Text="Audio opis" Width="300"/>
                                </wf:ListView.Columns>
                            </wf:ListView>
                        </wfhost:WindowsFormsHost>
                    </Border>

                    <TextBlock x:Name="txtTimelineInfo" Grid.Row="3" Foreground="#00E676" Text="Ukupno klipova: 0 | Ukupno trajanje: 0:00 | Zoom: 1.0x" Margin="0,10,0,0"/>
                </Grid>
            </TabItem>

            <TabItem x:Name="tabAI" Header="🤖 AI FUNKCIJE">
                <ScrollViewer>
                    <StackPanel Margin="20">
                        <Border Background="#1E1E1E" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock x:Name="txtAIVoice" Text="🗣 AI GLAS" FontSize="16" FontWeight="Bold" Foreground="#00E676"/>
                                <TextBlock x:Name="txtVoiceTextLabel" Text="Tekst za govor:" Foreground="White" Margin="0,10,0,5"/>
                                <TextBox x:Name="txtVoiceText" Height="60" TextWrapping="Wrap" Padding="10" Background="#2D2D2D" Foreground="White" AcceptsReturn="True"/>
                                <StackPanel Orientation="Horizontal" Margin="0,10">
                                    <RadioButton x:Name="rbSrb" Content="Srpski" IsChecked="True" Foreground="White" Margin="0,0,20,0"/>
                                    <RadioButton x:Name="rbEng" Content="English" Foreground="White"/>
                                </StackPanel>
                                <Button x:Name="btnGenerateVoice" Content="🗣 GENERISI GLAS" Click="GenerateVoice_Click" Height="40" Background="#00E676" FontWeight="Bold" Margin="0,10"/>
                                <ProgressBar x:Name="prgVoice" Height="6" Visibility="Collapsed"/>
                                <TextBlock x:Name="txtVoiceStatus" Foreground="Yellow"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#1E1E1E" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock x:Name="txtAIFrames" Text="🎨 AI KADROVI" FontSize="16" FontWeight="Bold" Foreground="#AA00FF"/>
                                <TextBlock x:Name="txtAIPromptLabel" Text="Opis slike (odvoji zarezom):" Foreground="White" Margin="0,10,0,5"/>
                                <TextBox x:Name="txtAIPrompt" Height="60" TextWrapping="Wrap" Padding="10" Background="#2D2D2D" Foreground="White" AcceptsReturn="True" Width="400" AutomationProperties.Name="Polje za unos opisa slike" AutomationProperties.HelpText="Unesite opis slike odvojen zarezom. Koristite Ctrl+V za lepljenje."/>
                                <Button x:Name="btnPastePrompt" Content="📋 Zalepi" Click="PastePrompt_Click" Width="80" Height="35" Margin="10,0,0,0" Background="#4A148C" Foreground="White" AutomationProperties.Name="Zalepi prompt iz klipborda" AutomationProperties.HelpText="Kliknite da nalepite tekst iz klipborda u polje za opis"/>
                                <Button x:Name="btnGenerate" Content="🎨 GENERISI AI KADROVE" Click="GenerateAI_Click" Height="40" Margin="0,10" Background="#AA00FF" Foreground="White" FontWeight="Bold" AutomationProperties.Name="Generiši AI kadrove" AutomationProperties.HelpText="Kliknite da generišete slike na osnovu unetog opisa"/>
                                <Button x:Name="btnPollinations" Content="🌸 POLLINATIONS.AI (besplatno, bez API)" Click="GenerateWithPollinations_Click" Height="40" Margin="0,0,0,10" Background="#006064" Foreground="White" FontWeight="Bold" AutomationProperties.Name="Generisi slike pomocu Pollinations.ai, besplatno, bez API kljuca" AutomationProperties.HelpText="Alternativa za generisanje slika. Ne trazi API kljuc."/>
                                <Button x:Name="btnSkiaAnimation" Content="✨ SKIA ANIMACIJA TEKSTA" Click="GenerateSkiaAnimation_Click" Height="40" Margin="0,0,0,10" Background="#1A237E" Foreground="White" FontWeight="Bold" AutomationProperties.Name="Napravi animaciju teksta pomocu SkiaSharp. Odaberi tekst, stil, boje i trajanje." AutomationProperties.HelpText="Kreira animirani video klip sa tvojim tekstom. FadeIn, SlideLeft, Bounce, Stars, Rainbow i drugi stilovi."/>
                                <ProgressBar x:Name="prgAI" Height="6" Visibility="Collapsed"/>
                                <TextBlock x:Name="txtAIStatus" Foreground="Yellow"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#1E1E1E" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock x:Name="txtAITranscribe" Text="🎤 AI TRANSKRIPCIJA" FontSize="16" FontWeight="Bold" Foreground="#00BCD4"/>
                                <TextBlock x:Name="txtTranscribeLabel" Text="Audio fajl za transkripciju:" Foreground="White" Margin="0,10,0,5"/>
                                <ComboBox x:Name="cmbTranscribeAudio" Height="30" Background="#2D2D2D" Foreground="White" SelectionChanged="TranscribeAudio_Selected"/>
                                <Button x:Name="btnTranscribe" Content="🎤 TRANSKRIBUJ" Click="TranscribeAudio_Click" Height="40" Background="#00BCD4" FontWeight="Bold" Margin="0,10"/>
                                <TextBox x:Name="txtTranscriptionResult" Height="100" TextWrapping="Wrap" Background="#2D2D2D" Foreground="White" IsReadOnly="True" Margin="0,10,0,0" VerticalScrollBarVisibility="Auto"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#1E1E1E" CornerRadius="8" Padding="15">
                            <StackPanel>
                                <TextBlock x:Name="txtAILyrics" Text="🎤 AI SINHRONIZACIJA TEKSTA" FontSize="16" FontWeight="Bold" Foreground="#FF9800"/>
                                <TextBlock x:Name="txtLyricsLabel" Text="Tekst pesme (stih po redu):" Foreground="White" Margin="0,10,0,5"/>
                                <TextBox x:Name="txtLyrics" Height="80" TextWrapping="Wrap" Padding="10" Background="#2D2D2D" Foreground="White" AcceptsReturn="True"/>
                                <TextBlock x:Name="txtSelectAudioLabel" Text="Selektuj audio klip:" Foreground="White" Margin="0,10,0,5"/>
                                <ComboBox x:Name="cmbAudioClips" Height="30" Background="#2D2D2D" Foreground="White" SelectionChanged="AudioClip_Selected"/>
                                <Button x:Name="btnSyncLyrics" Content="🎤 SINHRONIZUJ TEKST" Click="SyncLyrics_Click" Height="40" Background="#FF9800" FontWeight="Bold" Margin="0,10"/>
                                <ProgressBar x:Name="prgSync" Height="6" Visibility="Collapsed"/>
                                <TextBlock x:Name="txtSyncStatus" Foreground="Yellow"/>
                                <ListBox x:Name="lstAutoSubtitles" Height="80" Background="#2D2D2D" Foreground="White" Margin="0,10"/>
                                <Button x:Name="btnAddSyncedSubtitles" Content="➕ DODAJ TITLOVE" Click="AddSyncedSubtitles_Click" Height="35" Background="#2E7D32" Foreground="White"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="tabEffects" Header="🎨 EFEKTI">
                <ScrollViewer>
                    <StackPanel Margin="20">
                        <TextBlock x:Name="txtVideoEffects" Text="🎬 VIDEO EFEKTI" FontSize="16" FontWeight="Bold" Foreground="#FF9800"/>
                        <TextBlock x:Name="txtBrightness" Text="Svetlina:" Foreground="White"/>
                        <Slider x:Name="sldBrightness" Minimum="-100" Maximum="100" Value="0" Margin="0,5,0,15"/>
                        <TextBlock x:Name="txtContrast" Text="Kontrast:" Foreground="White"/>
                        <Slider x:Name="sldContrast" Minimum="-100" Maximum="100" Value="0" Margin="0,5,0,15"/>
                        <TextBlock x:Name="txtBlur" Text="Zamagljenje:" Foreground="White"/>
                        <Slider x:Name="sldBlur" Minimum="0" Maximum="20" Value="0" Margin="0,5,0,15"/>
                        <Separator Margin="0,20"/>
                        <TextBlock x:Name="txtAudioEffects" Text="🎵 AUDIO EFEKTI" FontSize="16" FontWeight="Bold" Foreground="#FF9800"/>
                        <TextBlock x:Name="txtBass" Text="Bas pojačanje:" Foreground="White"/>
                        <StackPanel Orientation="Horizontal">
                            <Slider x:Name="sldBass" Minimum="0" Maximum="20" Value="0" Width="200" ValueChanged="AudioEffect_ValueChanged"/>
                            <Button x:Name="btnPreviewBass" Content="👂 PRESLUŠAJ" Click="PreviewBass_Click" Width="100" Height="25" Margin="10,0" Background="#FF9800" Foreground="White"/>
                        </StackPanel>
                        <TextBlock x:Name="txtTreble" Text="Treble pojačanje:" Foreground="White"/>
                        <StackPanel Orientation="Horizontal">
                            <Slider x:Name="sldTreble" Minimum="0" Maximum="20" Value="0" Width="200" ValueChanged="AudioEffect_ValueChanged"/>
                            <Button x:Name="btnPreviewTreble" Content="👂 PRESLUŠAJ" Click="PreviewTreble_Click" Width="100" Height="25" Margin="10,0" Background="#FF9800" Foreground="White"/>
                        </StackPanel>
                        <CheckBox x:Name="chkGPUAcceleration" Content="🎮 GPU ubrzanje" Foreground="White" Margin="0,15" IsChecked="True" Checked="GPUAcceleration_Checked" Unchecked="GPUAcceleration_Checked"/>
                        <TextBlock x:Name="txtReverb" Text="Reverb:" Foreground="White"/>
                        <StackPanel Orientation="Horizontal">
                            <Slider x:Name="sldReverb" Minimum="0" Maximum="100" Value="0" Width="200" ValueChanged="AudioEffect_ValueChanged"/>
                            <Button x:Name="btnPreviewReverb" Content="👂 PRESLUŠAJ" Click="PreviewReverb_Click" Width="100" Height="25" Margin="10,0" Background="#FF9800" Foreground="White"/>
                        </StackPanel>
                        <TextBlock x:Name="txtPreviewDuration" Text="Dužina pregleda (sekundi):" Foreground="White" Margin="0,10,0,5"/>
                        <StackPanel Orientation="Horizontal">
                            <Slider x:Name="sldPreviewDuration" Minimum="3" Maximum="30" Value="10" Width="200" TickFrequency="1" TickPlacement="BottomRight"/>
                            <TextBlock x:Name="txtPreviewDurationValue" Text="10 s" Foreground="Yellow" Margin="10,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <CheckBox x:Name="chkCompressor" Content="Kompresor" Foreground="White" Margin="0,15" Checked="AudioEffect_ValueChanged" Unchecked="AudioEffect_ValueChanged"/>
                        <Button x:Name="btnApplyEffects" Content="💾 PRIMENI EFEKTE" Click="ApplyEffects_Click" Height="45" Background="#4A148C" Foreground="White" Margin="0,20"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="tabSubtitles" Header="📝 TITLOVI">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock x:Name="txtSubtitleTextLabel" Text="Tekst titla:" Foreground="White"/>
                        <TextBox x:Name="txtSubtitleText" Height="60" TextWrapping="Wrap" Background="#1E1E1E" Foreground="White" Margin="0,5,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="txtSubStartLabel" Text="Početak (s): " Foreground="White" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtSubStart" Width="80" Text="0" Margin="0,0,20,0"/>
                            <TextBlock x:Name="txtSubEndLabel" Text="Kraj (s): " Foreground="White" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtSubEnd" Width="80" Text="5" Margin="0,0,20,0"/>
                            <Button x:Name="btnAddSubtitle" Content="➕ DODAJ TITL" Click="AddSubtitle_Click" Width="120" Height="35" Background="#2E7D32" Foreground="White"/>
                        </StackPanel>
                    </StackPanel>
                    <ListBox x:Name="lstSubtitles" Grid.Row="1" Background="#1E1E1E" Foreground="White"/>
                    <Button x:Name="btnClearSubtitles" Content="🗑 OBRIŠI SVE TITLOVE" Click="ClearSubtitles_Click" Background="#B71C1C" Foreground="White" Height="40" Margin="0,10,0,0"/>
                </Grid>
            </TabItem>

            <TabItem x:Name="tabTransitions" Header="🎬 TRANZICIJE">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="txtTransitionsInfo" Text="Prevuci efekat između dva klipa na vremenskoj traci" Foreground="#00E676" Margin="0,0,0,10" TextAlignment="Center"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock x:Name="txtTransitionDuration" Text="Trajanje efekta (s):" Foreground="White" VerticalAlignment="Center"/>
                        <Slider x:Name="sldTransitionDuration" Minimum="0.5" Maximum="5" Value="1" Width="150" Margin="10,0" TickFrequency="0.5" TickPlacement="BottomRight" ValueChanged="sldTransitionDuration_ValueChanged"/>
                        <TextBlock x:Name="txtTransitionDurationValue" Text="1.0 s" Foreground="Yellow" Margin="10,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ListBox x:Name="lstTransitions" Grid.Row="2" Background="#1E1E1E" Foreground="White" SelectionChanged="Transition_Selected" Margin="0,0,0,10">
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Dodaj između selektovana dva klipa" Click="AddTransitionBetweenSelected_Click"/>
                                <MenuItem Header="Dodaj između klipova po izboru..." Click="AddTransitionBetweenSpecific_Click"/>
                                <Separator/>
                                <MenuItem Header="Ukloni tranziciju" Click="RemoveTransition_Click"/>
                                <Separator/>
                                <MenuItem Header="Podesi trajanje" Click="SetTransitionDuration_Click"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="5">
                                    <TextBlock Text="{Binding Icon}" FontSize="20" Width="40"/>
                                    <TextBlock Text="{Binding Name}" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text=" (prevuci)" FontSize="12" Foreground="Gray" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button x:Name="btnRemoveTransition" Content="🗑 UKLONI TRANZICIJU" Click="RemoveTransition_Click" Grid.Row="3" Height="35" Background="#B71C1C" Foreground="White"/>
                </Grid>
            </TabItem>

            <TabItem x:Name="tabAnimation" Header="🎬 ANIMACIJE">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="txtAnimInfo" Text="Keyframe animacije za selektovani klip" Foreground="#00E676" Margin="0,0,0,10" TextAlignment="Center"/>
                    <TextBlock Grid.Row="1" x:Name="txtSelectedClip" Text="Selektovan klip: nijedan" Foreground="Yellow" Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock x:Name="txtKeyframeList" Text="Keyframe-ovi:" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ListBox x:Name="lstKeyframes" Width="200" Height="100" Background="#2D2D2D" Foreground="White" SelectionChanged="Keyframe_Selected" Margin="0,0,10,0">
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Dodaj keyframe na trenutnu poziciju" Click="AddKeyframe_Click" InputGestureText="Ctrl+K"/>
                                    <MenuItem Header="Ukloni keyframe" Click="RemoveKeyframe_Click" InputGestureText="Ctrl+Shift+K"/>
                                    <MenuItem Header="Primeni na keyframe" Click="ApplyKeyframe_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Postavi zoom" Click="SetZoomKeyframe_Click"/>
                                    <MenuItem Header="Postavi rotaciju" Click="SetRotationKeyframe_Click"/>
                                    <MenuItem Header="Postavi poziciju" Click="SetPositionKeyframe_Click"/>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="3">
                                        <TextBlock Text="📍" FontSize="14" Width="25"/>
                                        <TextBlock Text="{Binding Time}" Foreground="#00E676" Width="50"/>
                                        <TextBlock Text=" zoom:" Foreground="Gray" FontSize="10"/>
                                        <TextBlock Text="{Binding Zoom}" Foreground="Yellow" Width="35"/>
                                        <TextBlock Text=" rot:" Foreground="Gray" FontSize="10"/>
                                        <TextBlock Text="{Binding Rotation}" Foreground="Yellow" Width="35"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Button x:Name="btnAddKeyframe" Content="➕ DODAJ" Click="AddKeyframe_Click" Width="80" Height="30" Background="#2E7D32" Foreground="White"/>
                        <Button x:Name="btnRemoveKeyframe" Content="🗑 UKLONI" Click="RemoveKeyframe_Click" Width="80" Height="30" Background="#B71C1C" Foreground="White" Margin="5,0,0,0"/>
                    </StackPanel>

                    <Border Grid.Row="3" Background="#2D2D2D" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="🤖 AI VODIČ ZA ANIMACIJE" FontSize="14" FontWeight="Bold" Foreground="#FF9800" Margin="0,0,0,10"/>
                            <TextBlock Text="Opis željene animacije:" Foreground="White" Margin="0,5,0,5"/>
                            <TextBox x:Name="txtAnimationPrompt" Height="60" TextWrapping="Wrap" Padding="10" Background="#2D2D2D" Foreground="White" AcceptsReturn="True" AutomationProperties.Name="Polje za opis animacije" AutomationProperties.HelpText="Opišite kakvu animaciju želite da napravite"/>
                            <StackPanel Orientation="Horizontal" Margin="0,10">
                                <Button x:Name="btnGenerateScenario" Content="🔮 Generiši scenario" Click="GenerateScenario_Click" Width="150" Height="35" Background="#4A148C" Foreground="White" Margin="0,0,10,0"/>
                                <Button x:Name="btnAISuggestLayout" Content="🎲 AI predloži raspored" Click="AISuggestLayout_Click" Width="180" Height="35" Background="#AA00FF" Foreground="White"/>
                            </StackPanel>
                            <TextBlock Text="Predlog scenarija (možete mijenjati):" Foreground="White" Margin="0,10,0,5"/>
                            <ListBox x:Name="lstAnimationScenes" Height="150" Background="#1E1E1E" Foreground="White" AutomationProperties.Name="Lista scena za animaciju">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#444" BorderThickness="0,0,0,1" Padding="5">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Description}" Foreground="#00E676" FontWeight="Bold"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                    <TextBlock Text="Slika:" Foreground="White" VerticalAlignment="Center" Width="50"/>
                                                    <ComboBox ItemsSource="{Binding AvailableImages}" SelectedItem="{Binding ImageName}" Width="120" AutomationProperties.Name="Izbor slike"/>
                                                    <TextBlock Text="Trajanje:" Foreground="White" VerticalAlignment="Center" Width="70" Margin="10,0"/>
                                                    <TextBox Text="{Binding Duration}" Width="50" AutomationProperties.Name="Trajanje u sekundama"/>
                                                    <TextBlock Text="Efekat:" Foreground="White" VerticalAlignment="Center" Width="50" Margin="10,0"/>
                                                    <ComboBox ItemsSource="{Binding AvailableEffects}" SelectedItem="{Binding Effect}" Width="100" AutomationProperties.Name="Izbor efekta"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Orientation="Horizontal" Margin="0,10">
                                <Button x:Name="btnAddScene" Content="➕ Dodaj scenu" Click="AddScene_Click" Width="100" Margin="0,0,5,0"/>
                                <Button x:Name="btnRemoveScene" Content="🗑 Obriši scenu" Click="RemoveScene_Click" Width="100" Margin="5,0"/>
                                <Button x:Name="btnMoveSceneUp" Content="🔼 Gore" Click="MoveSceneUp_Click" Width="80" Margin="5,0"/>
                                <Button x:Name="btnMoveSceneDown" Content="🔽 Dolje" Click="MoveSceneDown_Click" Width="80" Margin="5,0"/>
                            </StackPanel>
                            <TextBlock Text="Ručno pozicioniranje:" Foreground="White" Margin="0,10,0,5"/>
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <TextBlock Text="Početna sekunda:" Foreground="White" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtAnimationStartTime" Width="60" Text="0" Margin="5,0" AutomationProperties.Name="Početna pozicija animacije u sekundama"/>
                                <Button x:Name="btnSetAnimationPosition" Content="📍 POSTAVI ANIMACIJU NA POZICIJU" Click="SetAnimationPosition_Click" Width="220" Height="35" Background="#FF9800" Foreground="White" Margin="10,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="4" Background="#2D2D2D" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock x:Name="txtAnimZoom" Text="Zoom (0.5 - 3.0):" Foreground="White"/>
                            <Slider x:Name="sldZoom" Minimum="0.5" Maximum="3.0" Value="1.0" Width="200" TickFrequency="0.1" TickPlacement="BottomRight" ValueChanged="AnimValue_Changed"/>
                            <TextBlock x:Name="txtZoomValue" Text="1.00" Foreground="Yellow" Margin="10,0"/>
                            <TextBlock x:Name="txtAnimRotation" Text="Rotacija (stepeni):" Foreground="White" Margin="0,10,0,0"/>
                            <Slider x:Name="sldRotation" Minimum="-360" Maximum="360" Value="0" Width="200" TickFrequency="10" TickPlacement="BottomRight" ValueChanged="AnimValue_Changed"/>
                            <TextBlock x:Name="txtRotationValue" Text="0°" Foreground="Yellow" Margin="10,0"/>
                            <TextBlock x:Name="txtAnimX" Text="Pomeranje X (px):" Foreground="White" Margin="0,10,0,0"/>
                            <Slider x:Name="sldX" Minimum="-500" Maximum="500" Value="0" Width="200" TickFrequency="10" TickPlacement="BottomRight" ValueChanged="AnimValue_Changed"/>
                            <TextBlock x:Name="txtXValue" Text="0" Foreground="Yellow" Margin="10,0"/>
                            <TextBlock x:Name="txtAnimY" Text="Pomeranje Y (px):" Foreground="White" Margin="0,10,0,0"/>
                            <Slider x:Name="sldY" Minimum="-500" Maximum="500" Value="0" Width="200" TickFrequency="10" TickPlacement="BottomRight" ValueChanged="AnimValue_Changed"/>
                            <TextBlock x:Name="txtYValue" Text="0" Foreground="Yellow" Margin="10,0"/>
                            <TextBlock x:Name="txtAnimOpacity" Text="Providnost (0-1):" Foreground="White" Margin="0,10,0,0"/>
                            <Slider x:Name="sldOpacity" Minimum="0" Maximum="1" Value="1" Width="200" TickFrequency="0.05" TickPlacement="BottomRight" ValueChanged="AnimValue_Changed"/>
                            <TextBlock x:Name="txtOpacityValue" Text="1.00" Foreground="Yellow" Margin="10,0"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                        <Button x:Name="btnApplyKeyframe" Content="💾 PRIMENI KEYFRAME" Click="ApplyKeyframe_Click" Width="150" Height="35" Background="#FF9800" Foreground="White" Margin="0,0,10,0"/>
                        <Button x:Name="btnPreviewAnimation" Content="👁️ PREGLEDAJ" Click="PreviewAnimation_Click" Width="120" Height="35" Background="#00BCD4" Foreground="White"/>
                        <Button x:Name="btnCreateAnimationFromScenes" Content="🎬 NAPRAVI ANIMACIJU" Click="CreateAnimationFromScenes_Click" Width="180" Height="35" Background="#2E7D32" Foreground="White" FontWeight="Bold" Margin="10,0,0,0"/>
                    </StackPanel>

                    <TextBlock Grid.Row="6" x:Name="txtAnimHelp" Text="Napomena: Keyframe animacije se primenjuju na RENDER (finalni video)" Foreground="Gray" FontSize="11" Margin="0,10,0,0"/>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
            <Button x:Name="btnSeekBack" Content="⏪ -5s" Click="SeekBack_Click" Width="70" Height="35" Background="#333" Foreground="White"/>
            <Button x:Name="btnPlay" Content="▶ PLAY" Click="TogglePlay_Click" Width="90" Height="35" Margin="5,0" Background="#1A237E" Foreground="White"/>
            <Button x:Name="btnSeekForward" Content="+5s ⏩" Click="SeekForward_Click" Width="70" Height="35" Background="#333" Foreground="White"/>
            <TextBlock x:Name="txtCurrentPosition" Foreground="Yellow" Text="0:00 / 0:00" VerticalAlignment="Center" Margin="15,0,0,0" FontSize="12"/>
            <TextBlock x:Name="txtMarkerStatus" Foreground="#FF9800" Text="" VerticalAlignment="Center" Margin="15,0,0,0"/>
        </StackPanel>

        <!-- ════════════════════════════════════════════════════════════════
             STATUS BAR — uvijek vidljiv, JAWS/NVDA čita automatski (Assertive)
             Korisnik NIKAD ne treba otvarati Ctrl+Shift+L da bi dobio info.
             ════════════════════════════════════════════════════════════════ -->
        <Border x:Name="statusBarBorder" Grid.Row="4" Background="#111111" BorderBrush="#333333" BorderThickness="0,1,0,0"
                VerticalAlignment="Bottom" Margin="0,0,0,0" Padding="6,3,6,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Glavna statusna poruka — JAWS cita svaku promjenu odmah (Assertive) -->
                <TextBox x:Name="txtJawsLog"
                         Grid.Column="0"
                         IsReadOnly="True"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#00FF00"
                         Text="Sistem spreman..."
                         TextWrapping="Wrap"
                         FontSize="11"
                         VerticalAlignment="Center"
                         AutomationProperties.LiveSetting="Assertive"
                         AutomationProperties.Name="Statusna poruka"
                         ToolTip="Statusne poruke. JAWS cita automatski. Ctrl+Shift+L za detaljan log."/>
                <!-- Desni info: pozicija / trajanje -->
                <TextBlock x:Name="txtStatus"
                           Grid.Column="1"
                           Foreground="#00E676"
                           Text="Status: Idle"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="10,0,0,0"
                           FontSize="10"/>
            </Grid>
        </Border>
        <!-- Nevidljiv element koji drzi JAWS ghost za duple poruke — zadrzano radi kompatibilnosti -->
        <TextBox x:Name="txtJawsGhost" Grid.Row="4" Height="1" Width="1" Opacity="0" IsReadOnly="True"
                 Background="Transparent" BorderThickness="0" IsTabStop="False"
                 AutomationProperties.LiveSetting="Assertive" AutomationProperties.Name=""/>

        <ProgressBar x:Name="prgRender" Grid.Row="4" Height="8" VerticalAlignment="Bottom" Margin="0,0,0,0" Visibility="Collapsed"/>
        <TextBlock x:Name="txtRenderStatus" Grid.Row="4" Foreground="Yellow" TextAlignment="Center" FontSize="10" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- txtStatus preseljen unutar statusBarBorder -->
    </Grid>
</Window>