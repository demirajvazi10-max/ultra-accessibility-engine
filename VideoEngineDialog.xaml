<Window x:Class="UltraVideoEditor.VideoEngineDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Video Engine" Height="720" Width="780"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A2E" Foreground="White"
        AutomationProperties.Name="AI Video Engine - profesionalni automatski video montazer za decije pesme">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Naslov -->
        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,10">
            <TextBlock Text="AI VIDEO ENGINE" FontSize="22" FontWeight="Bold"
                       Foreground="#00E676" HorizontalAlignment="Center"/>
            <TextBlock Text="Profesionalni automatski video montazer za decije pesme"
                       Foreground="#888888" FontSize="11" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Status -->
        <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="6" Padding="10" Margin="0,0,0,8">
            <TextBlock x:Name="txtStatus" Text="Inicijalizacija..."
                       Foreground="#FF9800" TextWrapping="Wrap" FontSize="12"
                       AutomationProperties.LiveSetting="Assertive"
                       AutomationProperties.Name="Status AI engine-a"/>
        </Border>

        <!-- Opcije -->
        <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="6" Padding="12" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="STIL VIDEA" FontSize="12" FontWeight="Bold"
                               Foreground="#00E676" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Intent:" Foreground="White" Width="60" VerticalAlignment="Center"/>
                        <ComboBox x:Name="cmbIntent" Width="190" Height="26"
                                  Background="#2D2D2D" Foreground="White"
                                  AutomationProperties.Name="Stil i namjena videa">
                            <ComboBoxItem Tag="emotional" IsSelected="True">Emotional - ljubavna / porodica</ComboBoxItem>
                            <ComboBoxItem Tag="hype">Hype - energican, brzi rezovi</ComboBoxItem>
                            <ComboBoxItem Tag="dark">Dark - dramatican stil</ComboBoxItem>
                            <ComboBoxItem Tag="storytelling">Storytelling - narativni</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Medij:" Foreground="White" Width="60" VerticalAlignment="Center"/>
                        <ComboBox x:Name="cmbMedia" Width="130" Height="26"
                                  Background="#2D2D2D" Foreground="White"
                                  AutomationProperties.Name="Tip medija za preuzimanje">
                            <ComboBoxItem Tag="video" IsSelected="True">Video klipovi</ComboBoxItem>
                            <ComboBoxItem Tag="image">Slike</ComboBoxItem>
                        </ComboBox>
                        <CheckBox x:Name="chkTitles" Content="Titlovi"
                                  Foreground="White" Margin="12,0,0,0"
                                  VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="AI GENERISANJE" FontSize="12" FontWeight="Bold"
                               Foreground="#00E676" Margin="0,0,0,6"/>
                    <CheckBox x:Name="chkUseOllama"
                              Content="Koristi Ollama AI za query-je"
                              Foreground="White" Margin="0,0,0,4"
                              AutomationProperties.Name="Ukljuci Ollama AI za generisanje Pixabay search query-ja"/>
                    <CheckBox x:Name="chkAmbient" IsChecked="True"
                              Content="🎵 Ambijentalni zvukovi (Freesound)"
                              Foreground="White" Margin="0,4,0,4"
                              AutomationProperties.Name="Preuzmi ambijentalne zvukove sa Freesound i miksuj ispod muzike na 15 posto"/>
                    <TextBlock x:Name="txtFreesoundInfo" Text="Freesound: provjera..."
                               Foreground="#888888" FontSize="11" TextWrapping="Wrap"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="txtOllamaInfo"
                               Text="Ollama: provjera..." Foreground="#888888"
                               FontSize="11" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Stihovi -->
        <Border Grid.Row="3" Background="#1E1E1E" CornerRadius="6" Padding="12" Margin="0,0,0,8">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="STIHOVI PESME" FontSize="12" FontWeight="Bold"
                               Foreground="#00E676" VerticalAlignment="Center"/>
                    <TextBlock Text=" — jedan stih po redu (refren ce biti automatski prepoznat)"
                               Foreground="#888888" FontSize="11"
                               VerticalAlignment="Center" Margin="5,0,0,0"/>
                    <Button x:Name="btnAnalyze" Content="ANALIZIRAJ"
                            Click="btnAnalyze_Click" Height="24" Margin="10,0,0,0"
                            Background="#1565C0" Foreground="White" FontSize="11"
                            AutomationProperties.Name="Analiziraj stihove i generiši pregled shot liste"/>
                </StackPanel>
                <TextBox x:Name="txtLyrics" Height="85" TextWrapping="Wrap"
                         AcceptsReturn="True" Background="#2D2D2D" Foreground="White"
                         Padding="8" VerticalScrollBarVisibility="Auto"
                         AutomationProperties.Name="Stihovi pesme, jedan po redu"
                         AutomationProperties.HelpText="Unesite stihove pesme, jedan stih po redu. Refren ce biti automatski prepoznat po ponavljanju."/>
            </StackPanel>
        </Border>

        <!-- Shot lista pregled -->
        <Border Grid.Row="4" Background="#1E1E1E" CornerRadius="6" Padding="12" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="SHOT LISTA" FontSize="12" FontWeight="Bold"
                               Foreground="#00E676" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtShotCount" Text=""
                               Foreground="#888888" FontSize="11"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
                <ListBox x:Name="lstShots" Grid.Row="1"
                         Background="#2D2D2D" Foreground="White"
                         SelectionChanged="lstShots_SelectionChanged"
                         AutomationProperties.Name="Shot lista - navigiraj strelicama za opis svakog kadra">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="45"/>
                                    <ColumnDefinition Width="85"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="25"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Timestamp}"
                                           Foreground="#888888" FontSize="10"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Data.ShotType}"
                                           Foreground="#00E676" FontSize="11"
                                           FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding ChorusLabel}"
                                           Foreground="#FF9800" FontSize="10"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3"
                                           Text="{Binding VibeLabel}"
                                           Foreground="#AAAAAA" FontSize="10"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4"
                                           Text="{Binding Data.SearchQuery}"
                                           Foreground="White" FontSize="11"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Progress -->
        <StackPanel Grid.Row="5" Margin="0,0,0,8">
            <ProgressBar x:Name="prgProgress" Height="6" Minimum="0" Maximum="100"
                         Value="0" Visibility="Collapsed"
                         Background="#333" Foreground="#00E676"/>
            <TextBlock x:Name="txtProgress" Text="" Foreground="#AAAAAA"
                       FontSize="11" Margin="0,3,0,0" TextWrapping="Wrap"
                       AutomationProperties.LiveSetting="Assertive"/>
        </StackPanel>

        <!-- Dugmad -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="btnExportJson" Content="IZVEZI JSON"
                    Click="btnExportJson_Click" Height="34"
                    Background="#333" Foreground="White" Margin="0,0,6,0"
                    AutomationProperties.Name="Izvezi shot listu kao JSON fajl"/>
            <Button x:Name="btnGenerate" Grid.Column="1"
                    Content="KREIRAJ VIDEO" Click="btnGenerate_Click"
                    Height="34" Width="150" Margin="0,0,6,0"
                    Background="#2E7D32" Foreground="White" FontWeight="Bold"
                    AutomationProperties.Name="Pokreni kreiranje - preuzmi medije i dodaj na timeline"/>
            <Button x:Name="btnStop" Grid.Column="2"
                    Content="ZAUSTAVI" Click="btnStop_Click"
                    Height="34" Width="100" IsEnabled="False" Margin="0,0,6,0"
                    Background="#B71C1C" Foreground="White" FontWeight="Bold"
                    AutomationProperties.Name="Zaustavi operaciju"/>
            <Button x:Name="btnClose" Grid.Column="3"
                    Content="ZATVORI" Click="btnClose_Click"
                    Height="34" Width="90"
                    Background="#424242" Foreground="White"
                    AutomationProperties.Name="Zatvori dijalog"/>
        </Grid>
    </Grid>
</Window>
