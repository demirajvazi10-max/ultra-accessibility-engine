<Window x:Class="UltraVideoEditor.PositionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Postavi na audio osu" Height="580" Width="520"
        WindowStartupLocation="CenterOwner" Background="#1E1E1E"
        AutomationProperties.Name="Postavljanje slike na audio vremensku osu">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Postavi sliku na audio osu" FontSize="17" FontWeight="Bold"
                   Foreground="#00E676" HorizontalAlignment="Center" Margin="0,0,0,12"/>

        <Border Grid.Row="1" Background="#2A2A2A" CornerRadius="4" Padding="10" Margin="0,0,0,8">
            <TextBlock x:Name="txtAudioInfo" Foreground="#88CCFF" TextWrapping="Wrap"
                       AutomationProperties.LiveSetting="Polite"/>
        </Border>

        <Border Grid.Row="2" Background="#2A2A2A" CornerRadius="4" Padding="10" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock x:Name="txtImageName" Foreground="White" FontWeight="Bold" TextWrapping="Wrap"/>
                <TextBlock x:Name="txtImageDesc" Foreground="#AAFFAA" TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- RUČNO POZICIONIRANJE -->
        <Border Grid.Row="3" Background="#2A2A2A" CornerRadius="4" Padding="10" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="Ručno pozicioniranje:" Foreground="#00E676" FontWeight="Bold" Margin="0,0,0,8"/>

                <TextBlock Text="Početak (sekunda):" Foreground="White" Margin="0,5,0,3"/>
                <TextBox x:Name="txtStart" Width="100" Height="30" Background="#2D2D2D"
                         Foreground="White" FontSize="14" Padding="5"
                         AutomationProperties.Name="Početna pozicija u sekundama"/>

                <TextBlock Text="Kraj (sekunda):" Foreground="White" Margin="0,10,0,3"/>
                <TextBox x:Name="txtEnd" Width="100" Height="30" Background="#2D2D2D"
                         Foreground="White" FontSize="14" Padding="5"
                         AutomationProperties.Name="Završna pozicija u sekundama"/>

                <TextBlock Text="Trajanje (sekunde):" Foreground="White" Margin="0,10,0,3"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="txtDuration" Width="80" Height="30" Background="#2D2D2D"
                             Foreground="White" FontSize="14" Padding="5"
                             AutomationProperties.Name="Trajanje slike u sekundama"/>
                    <TextBlock Text=" sek" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="8,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- AUTOMATSKI RASPORED -->
        <Border Grid.Row="4" Background="#1A2A1A" CornerRadius="4" Padding="10" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="Automatski raspored:" Foreground="#00E676" FontWeight="Bold" Margin="0,0,0,6"/>
                <TextBlock x:Name="txtAutoInfo" Foreground="#AAAAAA" TextWrapping="Wrap" Margin="0,0,0,8"/>
                <Button x:Name="btnAutoPlace" Content="Ravnomerno rasporedi SVE slike po audio osi"
                        Click="AutoPlace_Click" Height="34" Background="#1B5E20" Foreground="White"
                        FontWeight="Bold"
                        AutomationProperties.Name="Ravnomerno rasporedi sve slike duz celog audio fajla"/>
            </StackPanel>
        </Border>

        <ListBox x:Name="lstSchedule" Grid.Row="5" Background="#111111" Foreground="White"
                 FontSize="11" Margin="0,0,0,8" Height="120"
                 AutomationProperties.Name="Trenutni raspored slika"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button x:Name="btnApply" Content="PRIMENI" Click="Apply_Click"
                    Width="110" Height="34" Background="#2E7D32" Foreground="White"
                    FontSize="13" FontWeight="Bold" Margin="0,0,10,0"
                    AutomationProperties.Name="Primeni poziciju"/>
            <Button x:Name="btnCancel" Content="OTKAZI" Click="Cancel_Click"
                    Width="110" Height="34" Background="#B71C1C" Foreground="White"
                    FontSize="13" FontWeight="Bold"
                    AutomationProperties.Name="Otkazi"/>
        </StackPanel>
    </Grid>
</Window>