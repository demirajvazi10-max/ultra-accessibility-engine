<Window x:Class="UltraVideoEditor.SubtitleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dodaj titl na klip" Height="250" Width="450"
        WindowStartupLocation="CenterOwner"
        Background="#2D2D2D">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Tekst titla:" Foreground="White" FontSize="14" Margin="0,0,0,10"/>
        <TextBox x:Name="txtText" Grid.Row="1" Height="60" TextWrapping="Wrap" 
                 Background="#1E1E1E" Foreground="White" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="2" Text="Show for entire clip" Foreground="#00E676" 
                   FontSize="12" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="btnOk" Content="✅ POTVRDI" Click="Ok_Click" Width="100" Height="35" 
                    Background="#2E7D32" Foreground="White" Margin="0,0,10,0"/>
            <Button x:Name="btnCancel" Content="❌ CANCEL" Click="Cancel_Click" Width="100" Height="35" 
                    Background="#B71C1C" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>