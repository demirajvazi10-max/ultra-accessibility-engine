<Window x:Class="UltraVideoEditor.ApiKeyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔑 Enter API key" Height="250" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1E1E1E">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="🔑 API Key for Pixabay" FontSize="16" FontWeight="Bold"
                   Foreground="#00E676" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="1" Text="Pixabay API key:" Foreground="White" Margin="0,0,0,5"/>

        <TextBox x:Name="txtApiKey" Grid.Row="2" Height="30" Padding="5" 
                 Background="#2D2D2D" Foreground="White" FontSize="12"
                 AutomationProperties.Name="API key field"/>

        <TextBlock Grid.Row="3" Text="How to get a key?" Foreground="#FF9800" 
                   Margin="0,10,0,0" Cursor="Hand" TextDecorations="Underline"
                   MouseLeftButtonDown="HelpLink_Click"/>

        <TextBlock Grid.Row="3" Text="pixabay.com/api/" Foreground="#2196F3" 
                   Margin="0,10,150,0" Cursor="Hand" TextDecorations="Underline"
                   MouseLeftButtonDown="HelpLink_Click"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="btnCancel" Content="Cancel" Width="80" Height="30"
                    Click="BtnCancel_Click" Background="#B71C1C" Foreground="White"
                    Margin="0,0,10,0"/>
            <Button x:Name="btnSave" Content="Save" Width="80" Height="30"
                    Click="BtnSave_Click" Background="#2E7D32" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>