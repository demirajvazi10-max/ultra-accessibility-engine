<UserControl x:Class="UltraAudioEditor.Views.Controls.AccessibleTrackList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AutomationProperties.Name="Ultra Audio Editor radni prostor">
    <Grid Background="{StaticResource BrBgDark}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Status traka -->
        <Border Grid.Row="0" Background="{StaticResource BrBgPanel}"
                BorderBrush="{StaticResource BrBorder}" BorderThickness="0,0,0,1" Padding="8,5">
            <StackPanel>
                <TextBlock x:Name="TxtProjectStatus" FontSize="11"
                           Foreground="{StaticResource BrText}" TextWrapping="Wrap"
                           AutomationProperties.LiveSetting="Polite"/>
                <TextBlock x:Name="TxtPlayhead" FontSize="11" Foreground="#4ECFA0" Margin="0,2,0,0"
                           AutomationProperties.LiveSetting="Assertive"/>
                <TextBlock x:Name="TxtSelection" FontSize="11" Foreground="#9D8FFF" Margin="0,2,0,0"
                           AutomationProperties.LiveSetting="Polite"/>
            </StackPanel>
        </Border>

        <!-- PLAYHEAD PANEL — slajder koji se pomjera strelicama -->
        <Border Grid.Row="1" Background="{StaticResource BrBgPanel}"
                BorderBrush="{StaticResource BrBorder}" BorderThickness="0,0,0,1"
                AutomationProperties.Name="Playhead kontrola. Tab za fokus na slajder, strelice za pomjeranje."
                AutomationProperties.LiveSetting="Polite">
            <StackPanel x:Name="PlayheadPanel"/>
        </Border>

        <!-- Glavni layout -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" MinWidth="150"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LIJEVO: Lista traka kao ListBox -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource BrBgPanel}"
                        BorderBrush="{StaticResource BrBorder}" BorderThickness="0,0,1,1" Padding="8,4">
                    <TextBlock Text="TRAKE" FontSize="10" FontWeight="Medium"
                               Foreground="{StaticResource BrTextMuted}"
                               AutomationProperties.Name="Lista traka projekta"/>
                </Border>

                <ListBox x:Name="TrackListBox" Grid.Row="1"
                         Background="{StaticResource BrBgDark}"
                         BorderThickness="0,0,1,0"
                         BorderBrush="{StaticResource BrBorder}"
                         SelectionMode="Single"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         AutomationProperties.Name="Lista traka. Strelice gore dole za navigaciju, Enter za otvaranje, Shift+F10 za meni."
                         SelectionChanged="TrackListBox_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{StaticResource BrText}"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BrBorder}"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="{TemplateBinding Padding}">
                                            <Border x:Name="SelBar" BorderThickness="0">
                                                <ContentPresenter/>
                                            </Border>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#1A2840"/>
                                                <Setter TargetName="SelBar" Property="BorderThickness" Value="3,0,0,0"/>
                                                <Setter TargetName="SelBar" Property="BorderBrush" Value="#7C6AF7"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#252535"/>
                                            </Trigger>
                                            <Trigger Property="IsFocused" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#1A2840"/>
                                                <Setter TargetName="SelBar" Property="BorderThickness" Value="3,0,0,0"/>
                                                <Setter TargetName="SelBar" Property="BorderBrush" Value="#7C6AF7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{StaticResource BrBorder}"/>

            <!-- DESNO: Track Workspace -->
            <Grid Grid.Column="2" x:Name="WorkspacePanel" Background="{StaticResource BrBgDark}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource BrBgPanel}"
                        BorderBrush="{StaticResource BrBorder}" BorderThickness="0,0,0,1" Padding="8,4">
                    <TextBlock x:Name="TxtWorkspaceTitle"
                               Text="Odaberite traku sa lijevog panela"
                               FontSize="11" FontWeight="Medium"
                               Foreground="{StaticResource BrTextMuted}"
                               AutomationProperties.LiveSetting="Polite"/>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="WorkspaceContent" Margin="0"/>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
