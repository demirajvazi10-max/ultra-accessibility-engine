<Window x:Class="UltraAudioEditor.Views.SetClipPositionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Postavi poziciju klipa"
        Width="420" Height="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BrBgDark}"
        ShowInTaskbar="False">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Naslov -->
        <TextBlock Grid.Row="0"
                   x:Name="TitleBlock"
                   FontSize="14" FontWeight="Medium"
                   Foreground="{StaticResource BrText}"
                   Margin="0,0,0,16"
                   AutomationProperties.HeadingLevel="Level1"/>

        <!-- Uputstvo -->
        <TextBlock Grid.Row="1"
                   Text="Unesite novu startnu poziciju klipa u sekundama:"
                   Foreground="{StaticResource BrTextSec}" FontSize="12"
                   Margin="0,0,0,8"
                   AutomationProperties.Name="Uputstvo: unesite poziciju u sekundama"/>

        <!-- Input u sekundama -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SecondsBox"
                     Grid.Column="0"
                     FontSize="18" Height="40"
                     TextAlignment="Right"
                     AutomationProperties.Name="Pozicija u sekundama"
                     AutomationProperties.HelpText="Unesite broj sekundi, npr. 15 ili 15.5"
                     KeyDown="SecondsBox_KeyDown"/>
            <TextBlock Grid.Column="1" Text=" s"
                       VerticalAlignment="Center"
                       FontSize="16" Foreground="{StaticResource BrTextSec}"
                       Margin="6,0,0,0"/>
        </Grid>

        <!-- Format MM:SS alternativa -->
        <TextBlock Grid.Row="3"
                   Text="ili u formatu MM:SS (npr. 0:15 ili 1:30):"
                   Foreground="{StaticResource BrTextSec}" FontSize="12"
                   Margin="0,0,0,8"/>

        <Grid Grid.Row="4" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TimeBox"
                     Grid.Column="0"
                     FontSize="16" Height="38"
                     AutomationProperties.Name="Pozicija u formatu minuti i sekundi"
                     AutomationProperties.HelpText="Unesite u formatu MM:SS, npr. 0:15 za 15 sekundi"
                     KeyDown="TimeBox_KeyDown"/>
            <TextBlock Grid.Column="1" Text=" MM:SS"
                       VerticalAlignment="Center"
                       FontSize="12" Foreground="{StaticResource BrTextSec}"
                       Margin="6,0,0,0"/>
        </Grid>

        <!-- Dugmad -->
        <StackPanel Grid.Row="6" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="BtnCancel" Margin="0,0,8,0" Content="Otkaži"
                    Style="{StaticResource StdButton}"
                    Width="90" Height="32"
                    Click="BtnCancel_Click"
                    AutomationProperties.Name="Otkaži postavljanje pozicije"/>
            <Button x:Name="BtnOk" Content="Postavi"
                    Style="{StaticResource AIButton}"
                    Width="90" Height="32"
                    IsDefault="True"
                    Click="BtnOk_Click"
                    AutomationProperties.Name="Potvrdi i postavi novu poziciju klipa"/>
        </StackPanel>
    </Grid>
</Window>
