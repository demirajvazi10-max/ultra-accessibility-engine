<Window x:Class="UltraAudioEditor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:UltraAudioEditor.ViewModels"
        xmlns:ctrl="clr-namespace:UltraAudioEditor.Controls"
        xmlns:vc="clr-namespace:UltraAudioEditor.Views.Controls"
        xmlns:models="clr-namespace:UltraAudioEditor.Models"
        Title="Ultra Audio Editor — Profesionalni Audio Editor"
        Height="820" Width="1280" MinHeight="600" MinWidth="900"
        Background="{StaticResource BrBgDark}"
        WindowStartupLocation="CenterScreen">

    <Window.InputBindings>
        <KeyBinding Key="Space" Command="{Binding PlayPauseCommand}"/>
        <KeyBinding Key="S" Command="{Binding StopCommand}"/>
        <KeyBinding Key="L" Command="{Binding LoopCommand}"/>
        <KeyBinding Key="Home" Command="{Binding ToStartCommand}"/>
        <KeyBinding Key="End" Command="{Binding ToEndCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl"       Command="{Binding SaveProjectCommand}"/>
        <KeyBinding Key="S" Modifiers="Ctrl+Shift" Command="{Binding SaveProjectAsCommand}"/>
        <KeyBinding Key="O" Modifiers="Ctrl"       Command="{Binding OpenProjectCommand}"/>
        <KeyBinding Key="I" Modifiers="Ctrl"       Command="{Binding ImportAudioCommand}"/>
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding ExportCommand}"/>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NewProjectCommand}"/>
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{Binding UndoCommand}"/>
        <KeyBinding Key="Y" Modifiers="Ctrl" Command="{Binding RedoCommand}"/>
        <KeyBinding Key="T" Modifiers="Ctrl+Alt" Command="{Binding AddTrackCommand}"/>
        <KeyBinding Key="Add" Modifiers="Ctrl" Command="{Binding ZoomInCommand}"/>
        <KeyBinding Key="Subtract" Modifiers="Ctrl" Command="{Binding ZoomOutCommand}"/>
        <KeyBinding Key="D0" Modifiers="Ctrl" Command="{Binding ZoomFitCommand}"/>
        <KeyBinding Key="Up" Modifiers="Alt" Command="{Binding MoveTrackUpCommand}"/>
        <KeyBinding Key="Down" Modifiers="Alt" Command="{Binding MoveTrackDownCommand}"/>
        <KeyBinding Key="D" Modifiers="Ctrl" Command="{Binding DuplicateTrackCommand}"/>
        <KeyBinding Key="W" Modifiers="Alt" Command="{Binding ToggleWorkspaceModeCommand}"/>
        <KeyBinding Key="F6" Command="{Binding AnnounceStatusCommand}"/>
        <!-- Clip pozicioniranje -->
        <KeyBinding Key="Left"  Modifiers="Ctrl"       Command="{Binding MoveClipLeftCommand}"/>
        <KeyBinding Key="Right" Modifiers="Ctrl"       Command="{Binding MoveClipRightCommand}"/>
        <KeyBinding Key="Left"  Modifiers="Ctrl+Shift" Command="{Binding MoveClipLeftFineCommand}"/>
        <KeyBinding Key="Right" Modifiers="Ctrl+Shift" Command="{Binding MoveClipRightFineCommand}"/>
        <KeyBinding Key="F2"                           Command="{Binding SetClipPositionCommand}"/>
        <KeyBinding Key="Delete" Modifiers="Shift"     Command="{Binding DeleteClipCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Menu -->
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="Auto"/>  <!-- Transport -->
            <RowDefinition Height="*"/>     <!-- Main Area -->
            <RowDefinition Height="Auto"/>  <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════ MENU BAR ═══════════ -->
        <Menu Grid.Row="0" Background="{StaticResource BrBgPanel}" Foreground="{StaticResource BrText}"
              AutomationProperties.Name="Glavni meni aplikacije">
            <MenuItem Header="_Fajl" AutomationProperties.Name="Fajl meni">
                <MenuItem Header="_Novi projekat (Ctrl+N)" Command="{Binding NewProjectCommand}"
                          AutomationProperties.Name="Novi projekat"/>
                <MenuItem Header="_Otvori projekat (Ctrl+O)" Command="{Binding OpenProjectCommand}"
                          AutomationProperties.Name="Otvori sacuvani projekat"/>
                <MenuItem Header="_Sačuvaj (Ctrl+S)" Command="{Binding SaveProjectCommand}"
                          AutomationProperties.Name="Sacuvaj projekat"/>
                <MenuItem Header="Sačuvaj _kao (Ctrl+Shift+S)" Command="{Binding SaveProjectAsCommand}"
                          AutomationProperties.Name="Sacuvaj projekat pod novim imenom"/>
                <Separator/>
                <MenuItem Header="_Uvezi audio (Ctrl+I)" Command="{Binding ImportAudioCommand}"
                          AutomationProperties.Name="Uvezi audio fajl"/>
                <Separator/>
                <MenuItem Header="_Izvezi audio (Ctrl+E)" Command="{Binding ExportCommand}"
                          AutomationProperties.Name="Izvezi audio"/>
                <Separator/>
                <MenuItem Header="I_zlaz" Click="MenuItem_Exit"
                          AutomationProperties.Name="Izlaz iz programa"/>
            </MenuItem>
            <MenuItem Header="_Uređivanje" AutomationProperties.Name="Meni za uređivanje">
                <MenuItem Header="_Poništi (Ctrl+Z)" Command="{Binding UndoCommand}" AutomationProperties.Name="Poništi"/>
                <MenuItem Header="_Ponovi (Ctrl+Y)" Command="{Binding RedoCommand}" AutomationProperties.Name="Ponovi"/>
                <Separator/>
                <MenuItem Header="_Normalizuj" Command="{Binding NormalizeCommand}" AutomationProperties.Name="Normalizuj glasnoću odabrane trake"/>
                <MenuItem Header="Fade _In" Command="{Binding FadeInCommand}" AutomationProperties.Name="Primijeni fade in"/>
                <MenuItem Header="Fade _Out" Command="{Binding FadeOutCommand}" AutomationProperties.Name="Primijeni fade out"/>
            </MenuItem>
            <MenuItem Header="_Klip" AutomationProperties.Name="Meni za upravljanje klipovima">
                <MenuItem Header="Postavi _poziciju... (F2)" Command="{Binding SetClipPositionCommand}"
                          AutomationProperties.Name="Postavi poziciju odabranog klipa"/>
                <MenuItem Header="Pomjeri lijevo 1s (Ctrl+Lijevo)" Command="{Binding MoveClipLeftCommand}"
                          AutomationProperties.Name="Pomjeri klip lijevo za jednu sekundu"/>
                <MenuItem Header="Pomjeri desno 1s (Ctrl+Desno)" Command="{Binding MoveClipRightCommand}"
                          AutomationProperties.Name="Pomjeri klip desno za jednu sekundu"/>
                <MenuItem Header="Pomjeri lijevo 0.1s (Ctrl+Shift+Lijevo)" Command="{Binding MoveClipLeftFineCommand}"
                          AutomationProperties.Name="Fino pomjeranje klipa lijevo"/>
                <MenuItem Header="Pomjeri desno 0.1s (Ctrl+Shift+Desno)" Command="{Binding MoveClipRightFineCommand}"
                          AutomationProperties.Name="Fino pomjeranje klipa desno"/>
                <Separator/>
                <MenuItem Header="_Obriši klip (Shift+Del)" Command="{Binding DeleteClipCommand}"
                          AutomationProperties.Name="Obriši odabrani klip"/>
            </MenuItem>
            <MenuItem Header="_Trake" AutomationProperties.Name="Meni za trake">
                <MenuItem Header="_Dodaj traku (Ctrl+Alt+T)" Command="{Binding AddTrackCommand}" AutomationProperties.Name="Dodaj novu traku"/>
                <MenuItem Header="_Obriši traku" Command="{Binding RemoveTrackCommand}" AutomationProperties.Name="Obriši odabranu traku"/>
                <MenuItem Header="D_upliraj traku (Ctrl+D)" Command="{Binding DuplicateTrackCommand}" AutomationProperties.Name="Dupliraj odabranu traku"/>
                <Separator/>
                <MenuItem Header="Pomjeri gore (Alt+Up)" Command="{Binding MoveTrackUpCommand}" AutomationProperties.Name="Pomjeri traku gore"/>
                <MenuItem Header="Pomjeri dole (Alt+Down)" Command="{Binding MoveTrackDownCommand}" AutomationProperties.Name="Pomjeri traku dole"/>
                <Separator/>
                <MenuItem Header="_Utišaj sve" Command="{Binding MuteAllCommand}" AutomationProperties.Name="Utišaj sve trake"/>
                <MenuItem Header="Aktiviraj _sve" Command="{Binding UnmuteAllCommand}" AutomationProperties.Name="Aktiviraj sve trake"/>
            </MenuItem>
            <MenuItem Header="A_I Funkcije" AutomationProperties.Name="Meni za AI funkcije">
                <MenuItem Header="AI _Transkripcija" Command="{Binding AiTranscribeCommand}" AutomationProperties.Name="AI transkripcija govora u tekst"/>
                <MenuItem Header="AI _Uklanjanje šuma" Command="{Binding AiNoiseRemoveCommand}" AutomationProperties.Name="AI uklanjanje pozadinskog šuma"/>
                <MenuItem Header="AI _SmartCut" Command="{Binding AiSmartCutCommand}" AutomationProperties.Name="AI detekcija tišine i pametno rezanje"/>
                <MenuItem Header="AI _Vocal Separator" Command="{Binding AiVocalSepCommand}" AutomationProperties.Name="AI odvajanje glasa od instrumentala"/>
                <MenuItem Header="AI _Opis projekta" Command="{Binding AiDescribeCommand}" AutomationProperties.Name="AI verbalni opis audio projekta"/>
                <MenuItem Header="AI Vocal _Mixer" Command="{Binding AiVocalMixCommand}" AutomationProperties.Name="AI preporuke za miksovanje glasa"/>
                <MenuItem Header="AI E_Q preporuke" Command="{Binding AiEqRecommendCommand}" AutomationProperties.Name="AI EQ preporuke za odabranu traku"/>
                <MenuItem Header="AI Auto _Level" Command="{Binding AiAutoLevelCommand}" AutomationProperties.Name="AI analiza i preporuke za nivoe glasnoće"/>
            </MenuItem>
            <MenuItem Header="_Pogled" AutomationProperties.Name="Meni za pogled">
                <MenuItem Header="Uvećaj (Ctrl++)" Command="{Binding ZoomInCommand}" AutomationProperties.Name="Uvećaj prikaz"/>
                <MenuItem Header="Umanji (Ctrl+-)" Command="{Binding ZoomOutCommand}" AutomationProperties.Name="Umanji prikaz"/>
                <MenuItem Header="Podesi na ekran (Ctrl+0)" Command="{Binding ZoomFitCommand}" AutomationProperties.Name="Podesi zoom na ekran"/>
            </MenuItem>
            <MenuItem Header="_Pomoć" AutomationProperties.Name="Meni za pomoć">
                <MenuItem Header="_Tastaturne prečice" Click="ShowShortcuts_Click" AutomationProperties.Name="Prikaži tastaturne prečice"/>
                <MenuItem Header="_O programu" Click="ShowAbout_Click" AutomationProperties.Name="O Ultra Audio Editor programu"/>
            </MenuItem>
        </Menu>

        <!-- ═══════════ TOOLBAR ═══════════ -->
        <ToolBar Grid.Row="1" Background="{StaticResource BrBgPanel}" Band="0"
                 AutomationProperties.Name="Toolbar sa alatima">
            <Button Command="{Binding NewProjectCommand}" ToolTip="Novi projekat (Ctrl+N)"
                    Style="{StaticResource StdButton}" AutomationProperties.Name="Novi projekat">Novi</Button>
            <Button Command="{Binding ImportAudioCommand}" ToolTip="Uvezi audio (Ctrl+I)"
                    Style="{StaticResource StdButton}" AutomationProperties.Name="Uvezi audio">Uvezi</Button>
            <Button Command="{Binding ExportCommand}" ToolTip="Izvezi (Ctrl+E)"
                    Style="{StaticResource StdButton}" AutomationProperties.Name="Izvezi audio">Izvezi</Button>
            <Separator/>
            <Button Command="{Binding UndoCommand}" ToolTip="Poništi (Ctrl+Z)"
                    Style="{StaticResource StdButton}" AutomationProperties.Name="Poništi">↩ Undo</Button>
            <Button Command="{Binding RedoCommand}" ToolTip="Ponovi (Ctrl+Y)"
                    Style="{StaticResource StdButton}" AutomationProperties.Name="Ponovi">↪ Redo</Button>
            <Separator/>
            <Button Command="{Binding NormalizeCommand}" ToolTip="Normalizuj glasnoću"
                    Style="{StaticResource StdButton}" AutomationProperties.Name="Normalizuj glasnoću odabrane trake">Normalizuj</Button>
            <Button Command="{Binding FadeInCommand}" ToolTip="Fade In"
                    Style="{StaticResource StdButton}" AutomationProperties.Name="Primijeni fade in">Fade In</Button>
            <Button Command="{Binding FadeOutCommand}" ToolTip="Fade Out"
                    Style="{StaticResource StdButton}" AutomationProperties.Name="Primijeni fade out">Fade Out</Button>
            <Separator/>
            <Button Command="{Binding ZoomOutCommand}" ToolTip="Umanji (Ctrl+-)"
                    Style="{StaticResource StdButton}" Width="28" AutomationProperties.Name="Umanji prikaz">−</Button>
            <TextBlock VerticalAlignment="Center" Foreground="{StaticResource BrTextSec}" FontSize="11" Margin="4,0"
                       AutomationProperties.Name="Trenutni nivo zuma">
                <TextBlock.Text>
                    <Binding Path="ZoomLevel" StringFormat="{}{0:F0}x" Mode="OneWay"/>
                </TextBlock.Text>
            </TextBlock>
            <Button Command="{Binding ZoomInCommand}" ToolTip="Uvećaj (Ctrl++)"
                    Style="{StaticResource StdButton}" Width="28" AutomationProperties.Name="Uvećaj prikaz">+</Button>
            <Button Command="{Binding ZoomFitCommand}" ToolTip="Fit (Ctrl+0)"
                    Style="{StaticResource StdButton}" AutomationProperties.Name="Podesi zoom na cijeli projekat">Fit</Button>
            <Separator/>
            <Button Command="{Binding AddTrackCommand}" ToolTip="Nova traka (Ctrl+Alt+T)"
                    Style="{StaticResource StdButton}" AutomationProperties.Name="Dodaj novu traku">+ Traka</Button>
        </ToolBar>

        <!-- ═══════════ TRANSPORT BAR ═══════════ -->
        <Border Grid.Row="2" Background="{StaticResource BrBgPanel}"
                BorderBrush="{StaticResource BrBorder}" BorderThickness="0,0,0,1"
                AutomationProperties.Name="Transport kontrole za reprodukciju">
            <Grid Margin="8,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Prikaz vremena -->
                <TextBlock Grid.Column="0"
                           Text="{Binding TimeDisplay, Mode=OneWay}"
                           FontFamily="Consolas" FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource BrText}"
                           VerticalAlignment="Center" Margin="0,0,16,0"
                           AutomationProperties.Name="Trenutna pozicija reproducije"
                           AutomationProperties.LiveSetting="Polite"/>

                <!-- Transport dugmad -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                            AutomationProperties.Name="Dugmad za transport">
                    <Button Command="{Binding ToStartCommand}" Style="{StaticResource TransportButton}"
                            ToolTip="Na početak (Home)" AutomationProperties.Name="Na početak" Margin="0,0,4,0">⏮</Button>
                    <Button Command="{Binding PlayPauseCommand}" Style="{StaticResource TransportButton}" Margin="0,0,4,0"
                            ToolTip="Reprodukuj/Pauziraj (Space)"
                            AutomationProperties.Name="Reprodukuj ili pauziraj"
                            Width="44" Height="44" FontSize="18">
                        <TextBlock Text="{Binding PlayPauseLabel, Mode=OneWay}" FontSize="14"/>
                    </Button>
                    <Button Command="{Binding StopCommand}" Style="{StaticResource TransportButton}"
                            ToolTip="Zaustavi (S)" AutomationProperties.Name="Zaustavi reprodukciju" Margin="0,0,4,0">■</Button>
                    <Button Command="{Binding RecordCommand}" Style="{StaticResource TransportButton}"
                            ToolTip="Snimi (R)" AutomationProperties.Name="Pokreni snimanje"
                            Foreground="{StaticResource BrDanger}" Margin="0,0,4,0">●</Button>
                    <Button Command="{Binding ToEndCommand}" Style="{StaticResource TransportButton}"
                            ToolTip="Na kraj (End)" AutomationProperties.Name="Na kraj projekta" Margin="0,0,4,0">⏭</Button>
                    <Button Command="{Binding LoopCommand}" Style="{StaticResource TransportButton}"
                            ToolTip="Loop (L)" AutomationProperties.Name="Uključi loop reprodukciju">⟳</Button>
                </StackPanel>

                <!-- Master Volume -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Label Content="Master:" Foreground="{StaticResource BrTextSec}" FontSize="11"
                           AutomationProperties.Name="Master glasnoća"/>
                    <Slider Width="100" Minimum="0" Maximum="1" Value="{Binding MasterVolume}"
                            TickFrequency="0.1" IsSnapToTickEnabled="False"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="Master glasnoća klizač"
                            AutomationProperties.HelpText="Podesi master glasnoću od 0 do 100 posto"/>
                    <TextBlock VerticalAlignment="Center" Margin="4,0" FontSize="11"
                               Foreground="{StaticResource BrTextSec}"
                               AutomationProperties.LiveSetting="Polite">
                        <TextBlock.Text>
                            <Binding Path="MasterVolume" StringFormat="{}{0:P0}" Mode="OneWay"/>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════ MAIN AREA ═══════════ -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>  <!-- Tracks + Timeline -->
                <ColumnDefinition Width="5" />  <!-- Splitter -->
                <ColumnDefinition Width="280"/> <!-- Right Panel -->
            </Grid.ColumnDefinitions>

            <!-- ─── LEFT: Dual-Mode Workspace ─── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Mode Bar -->
                <Border Grid.Row="0" Background="{StaticResource BrBgPanel}"
                        BorderBrush="{StaticResource BrBorder}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button x:Name="BtnVisualMode"
                                    Content="Vizualni mod"
                                    Style="{StaticResource StdButton}"
                                    Click="BtnVisualMode_Click"
                                    Margin="4,2,0,2"
                                    AutomationProperties.Name="Prebaci na vizualni waveform prikaz"
                                    ToolTip="Vizualni mod — waveform prikaz (Alt+W)"/>
                            <Button x:Name="BtnJawsMode"
                                    Content="JAWS mod (Alt+W)"
                                    Style="{StaticResource AIButton}"
                                    Click="BtnJawsMode_Click"
                                    Margin="4,2,0,2"
                                    AutomationProperties.Name="Prebaci na JAWS pristupacni tekstualni prikaz"
                                    ToolTip="JAWS mod — tekstualni pristupacni prikaz (Alt+W)"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   x:Name="CurrentModeLabel"
                                   Text="● VIZUALNI MOD"
                                   FontSize="10" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrTextMuted}"
                                   Margin="0,0,8,0"
                                   AutomationProperties.LiveSetting="Polite"/>
                    </Grid>
                </Border>

                <!-- ══ VIZUALNI MOD ══ -->
                <Grid Grid.Row="1" x:Name="VisualWorkspace">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Height="24" Background="{StaticResource BrBgPanel}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" BorderBrush="{StaticResource BrBorder}" BorderThickness="0,0,1,1">
                            <TextBlock Text="TRAKE" FontSize="10" Foreground="{StaticResource BrTextMuted}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <Canvas Grid.Column="1" x:Name="RulerCanvas" Background="{StaticResource BrBgPanel}" ClipToBounds="True"/>
                    </Grid>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                  AutomationProperties.Name="Lista audio traka vizualni prikaz">
                        <ItemsControl ItemsSource="{Binding Project.Tracks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:AudioTrack}">
                                    <Grid Height="{Binding Height}" MinHeight="64">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="{StaticResource BrBgPanel}"
                                                BorderBrush="{StaticResource BrBorder}" BorderThickness="0,0,1,1">
                                            <Border BorderBrush="{Binding ColorBrush, Mode=OneWay}" BorderThickness="3,0,0,0">
                                                <StackPanel Margin="6,4">
                                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource BrText}"
                                                               FontSize="12" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                        <ToggleButton Content="M" Width="24" Height="20" FontSize="10" Margin="0,0,3,0"
                                                                      IsChecked="{Binding IsMuted}"
                                                                      AutomationProperties.Name="Mute dugme"
                                                                      Background="{Binding IsMuted, Converter={StaticResource BoolToMuteBrush}}"/>
                                                        <ToggleButton Content="S" Width="24" Height="20" FontSize="10" Margin="0,0,3,0"
                                                                      IsChecked="{Binding IsSolo}"
                                                                      AutomationProperties.Name="Solo dugme"
                                                                      Background="{Binding IsSolo, Converter={StaticResource BoolToSoloBrush}}"/>
                                                        <TextBlock Text="{Binding Type}" FontSize="9"
                                                                   Foreground="{StaticResource BrTextMuted}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                        <TextBlock Text="Vol" FontSize="10" Foreground="{StaticResource BrTextMuted}"
                                                                   Width="24" VerticalAlignment="Center"/>
                                                        <Slider Width="100" Minimum="0" Maximum="1" Value="{Binding Volume}"
                                                                AutomationProperties.Name="Glasnoća trake"/>
                                                        <TextBlock FontSize="10" Foreground="{StaticResource BrTextSec}" Margin="3,0" VerticalAlignment="Center">
                                                            <TextBlock.Text><Binding Path="Volume" StringFormat="{}{0:P0}" Mode="OneWay"/></TextBlock.Text>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </Border>
                                        <Border Grid.Column="1" BorderBrush="{StaticResource BrBorder}"
                                                BorderThickness="0,0,0,1" Background="#0F0F1A">
                                            <ctrl:WaveformControl
                                                Clips="{Binding Clips}"
                                                TrackColor="{Binding Color}"
                                                PlayheadPosition="{Binding DataContext.PlayheadPosition, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"
                                                ProjectDuration="{Binding DataContext.Project.Duration, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"
                                                ZoomLevel="{Binding DataContext.ZoomLevel, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"
                                                AllowDrop="True" Drop="WaveformArea_Drop"
                                                MouseLeftButtonDown="WaveformArea_MouseDown">
                                                <ctrl:WaveformControl.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="Postavi poziciju klipa... (F2)"
                                                                  Command="{Binding DataContext.SetClipPositionCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                        <MenuItem Header="Pomjeri lijevo 1s (Ctrl+Lijevo)"
                                                                  Command="{Binding DataContext.MoveClipLeftCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                        <MenuItem Header="Pomjeri desno 1s (Ctrl+Desno)"
                                                                  Command="{Binding DataContext.MoveClipRightCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                        <MenuItem Header="Obriši klip (Shift+Delete)"
                                                                  Command="{Binding DataContext.DeleteClipCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                    </ContextMenu>
                                                </ctrl:WaveformControl.ContextMenu>
                                            </ctrl:WaveformControl>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- ══ JAWS MOD ══ -->
                <vc:AccessibleTrackList Grid.Row="1" x:Name="AccessibleTrackList"
                    Visibility="Collapsed"
                    AutomationProperties.Name="JAWS pristupacni prikaz traka i klipova"/>

            </Grid>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{StaticResource BrBorder}"
                          AutomationProperties.Name="Razdjelnik panela"/>

            <!-- ─── RIGHT PANEL ─── -->
            <Grid Grid.Column="2" Background="{StaticResource BrBgPanel}">
                <TabControl Background="{StaticResource BrBgPanel}"
                            Foreground="{StaticResource BrText}"
                            AutomationProperties.Name="Desni panel sa efektima i AI funkcijama">
                    <TabItem Header="Efekti" AutomationProperties.Name="Kartica efekti">
                        <TextBlock Text="Odaberite traku da vidite efekte." Margin="8"
                                   Foreground="{StaticResource BrTextSec}" FontSize="12"/>
                    </TabItem>
                    <TabItem Header="AI Funkcije" AutomationProperties.Name="Kartica AI funkcije">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8">
                                <TextBlock Text="Anthropic API Ključ" FontSize="11" FontWeight="Medium"
                                           Foreground="{StaticResource BrTextSec}" Margin="0,4,0,4"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <RadioButton Content="Groq (BESPLATNO)" IsChecked="{Binding UseGroq}"
                                                 Foreground="#4ECFA0" FontWeight="Medium" Margin="0,0,12,0"
                                                 AutomationProperties.Name="Koristi Groq AI, besplatno"/>
                                    <RadioButton Content="Anthropic Claude" IsChecked="{Binding UseAnthropic}"
                                                 Foreground="{StaticResource BrText}"
                                                 AutomationProperties.Name="Koristi Anthropic Claude AI"/>
                                </StackPanel>
                                <TextBlock Text="{Binding ApiKeyHint, Mode=OneWay}" FontSize="11" FontWeight="Medium"
                                           Foreground="{StaticResource BrTextSec}" Margin="0,4,0,4"/>
                                <PasswordBox x:Name="ApiKeyBox" Height="30"
                                             Background="{StaticResource BrBgMid}"
                                             Foreground="{StaticResource BrText}"
                                             BorderBrush="{StaticResource BrBorder}"
                                             BorderThickness="1"
                                             PasswordChanged="ApiKeyBox_PasswordChanged"
                                             AutomationProperties.Name="Unesi API ključ"/>
                                <Button Click="OpenApiKeyLink_Click"
                                        Style="{StaticResource StdButton}"
                                        HorizontalAlignment="Left"
                                        Margin="0,4,0,0" Height="22" Padding="4,2"
                                        AutomationProperties.Name="Otvori stranicu za API ključ">
                                    <TextBlock Text="{Binding ApiKeyLink, Mode=OneWay}" FontSize="10" Foreground="#4ECFA0"/>
                                </Button>
                                <TextBlock FontSize="10" Foreground="{StaticResource BrTextMuted}" Margin="0,2,0,8"
                                           Text="Groq: 14.400 besplatnih zahtjeva/dan"/>
                                <Separator Margin="0,4,0,8" Background="{StaticResource BrBorder}"/>
                                <Label Content="Jezik transkripcije:" AutomationProperties.Name="Odabir jezika"/>
                                <ComboBox SelectedItem="{Binding SelectedLanguage}" AutomationProperties.Name="Jezik transkripcije">
                                    <ComboBoxItem>Srpski</ComboBoxItem>
                                    <ComboBoxItem>Engleski</ComboBoxItem>
                                    <ComboBoxItem>Njemacki</ComboBoxItem>
                                    <ComboBoxItem>Francuski</ComboBoxItem>
                                    <ComboBoxItem>Auto-detect</ComboBoxItem>
                                </ComboBox>
                                <Label Content="Nivo uklanjanja suma:" Margin="0,6,0,0"/>
                                <ComboBox SelectedItem="{Binding SelectedNoiseLevel}" AutomationProperties.Name="Nivo noise removal">
                                    <ComboBoxItem>Blag</ComboBoxItem>
                                    <ComboBoxItem>Srednji</ComboBoxItem>
                                    <ComboBoxItem>Agresivan</ComboBoxItem>
                                </ComboBox>
                                <Label Content="Prag tisine (SmartCut):" Margin="0,6,0,0"/>
                                <StackPanel Orientation="Horizontal">
                                    <Slider Width="160" Minimum="-60" Maximum="-20" Value="{Binding SilenceThreshold}"
                                            AutomationProperties.Name="Prag tisine klizac"/>
                                    <TextBlock Margin="4,0" VerticalAlignment="Center" Foreground="{StaticResource BrText}">
                                        <TextBlock.Text><Binding Path="SilenceThreshold" StringFormat="{}{0:F0} dB" Mode="OneWay"/></TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                                <Separator Margin="0,8" Background="{StaticResource BrBorder}"/>
                                <Button Command="{Binding AiTranscribeCommand}" Style="{StaticResource AIButton}" Margin="0,0,0,4" HorizontalAlignment="Stretch" AutomationProperties.Name="AI transkripcija">Transkripcija govora</Button>
                                <Button Command="{Binding AiNoiseRemoveCommand}" Style="{StaticResource AIButton}" Margin="0,0,0,4" HorizontalAlignment="Stretch" AutomationProperties.Name="AI uklanjanje suma">Ukloni sum (Denoise)</Button>
                                <Button Command="{Binding AiSmartCutCommand}" Style="{StaticResource AIButton}" Margin="0,0,0,4" HorizontalAlignment="Stretch" AutomationProperties.Name="AI SmartCut">SmartCut (detekcija tisine)</Button>
                                <Button Command="{Binding AiVocalSepCommand}" Style="{StaticResource AIButton}" Margin="0,0,0,4" HorizontalAlignment="Stretch" AutomationProperties.Name="AI vocal separator">Vocal Separator (savjeti)</Button>
                                <Button Command="{Binding AiVocalMixCommand}" Style="{StaticResource AIButton}" Margin="0,0,0,4" HorizontalAlignment="Stretch" AutomationProperties.Name="AI vocal mix">Glas na Instrumental (mix)</Button>
                                <Button Command="{Binding AiEqRecommendCommand}" Style="{StaticResource AIButton}" Margin="0,0,0,4" HorizontalAlignment="Stretch" AutomationProperties.Name="AI EQ preporuke">EQ Preporuke (odabrana traka)</Button>
                                <Button Command="{Binding AiAutoLevelCommand}" Style="{StaticResource AIButton}" Margin="0,0,0,4" HorizontalAlignment="Stretch" AutomationProperties.Name="AI auto level">Auto Level (LUFS analiza)</Button>
                                <Button Command="{Binding AiDescribeCommand}" Style="{StaticResource AIButton}" Margin="0,0,0,4" HorizontalAlignment="Stretch" AutomationProperties.Name="AI opis projekta">Opis projekta (pristupacnost)</Button>
                                <Separator Margin="0,8" Background="{StaticResource BrBorder}"/>
                                <TextBlock Text="Napredak AI obrade:" FontSize="10" Foreground="{StaticResource BrTextMuted}" Margin="0,0,0,2"/>
                                <ProgressBar Height="8" Value="{Binding AiProgress, Mode=OneWay}" Maximum="100"
                                             Background="{StaticResource BrBgMid}" Foreground="{StaticResource BrAccentAI}"
                                             AutomationProperties.Name="AI napredak"/>
                                <TextBlock Text="Rezultati:" FontSize="10" Foreground="{StaticResource BrTextMuted}" Margin="0,8,0,2"/>
                                <TextBox Text="{Binding AiResult, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap"
                                         MinHeight="150" MaxHeight="300" VerticalScrollBarVisibility="Auto"
                                         FontSize="11" FontFamily="Consolas"
                                         AutomationProperties.Name="AI rezultati"
                                         AutomationProperties.LiveSetting="Polite"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="Izvoz" AutomationProperties.Name="Kartica izvoz">
                        <StackPanel Margin="8">
                            <TextBlock Text="Format izvoza" FontSize="11" FontWeight="Medium" Foreground="{StaticResource BrTextSec}" Margin="0,4,0,4"/>
                            <ComboBox SelectedItem="{Binding ExportFormat}" AutomationProperties.Name="Format za izvoz">
                                <ComboBoxItem>WAV</ComboBoxItem>
                                <ComboBoxItem>MP3</ComboBoxItem>
                                <ComboBoxItem>OGG</ComboBoxItem>
                                <ComboBoxItem>FLAC</ComboBoxItem>
                                <ComboBoxItem>M4A</ComboBoxItem>
                                <ComboBoxItem>AIFF</ComboBoxItem>
                            </ComboBox>
                            <Button Command="{Binding ExportCommand}" Style="{StaticResource AIButton}"
                                    Margin="0,16,0,0" HorizontalAlignment="Stretch" Height="36"
                                    AutomationProperties.Name="Pokreni izvoz audio fajla">Izvezi audio</Button>
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>

        <!-- ═══════════ STATUS BAR ═══════════ -->
        <StatusBar Grid.Row="4" Background="{StaticResource BrBgPanel}"
                   AutomationProperties.Name="Status traka programa">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage, Mode=OneWay}"
                           Foreground="{StaticResource BrText}" FontSize="11"
                           AutomationProperties.Name="Poruka statusa"
                           AutomationProperties.LiveSetting="Polite"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Foreground="{StaticResource BrTextSec}" FontSize="11">
                    <TextBlock.Text><Binding Path="Project.Tracks.Count" StringFormat="{}{0} traka" Mode="OneWay"/></TextBlock.Text>
                </TextBlock>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Foreground="{StaticResource BrTextSec}" FontSize="11">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0} Hz / {1}-bit" Mode="OneWay">
                            <Binding Path="Project.SampleRate"/>
                            <Binding Path="Project.BitDepth"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="Ultra Audio Editor v1.0 | JAWS pristupacno"
                           Foreground="{StaticResource BrTextMuted}" FontSize="10"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>