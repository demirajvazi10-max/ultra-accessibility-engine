<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Colors -->
    <Color x:Key="BgDark">#1E1E2E</Color>
    <Color x:Key="BgMid">#2A2A3E</Color>
    <Color x:Key="BgLight">#313145</Color>
    <Color x:Key="BgPanel">#252535</Color>
    <Color x:Key="Accent">#7C6AF7</Color>
    <Color x:Key="AccentHover">#9D8FFF</Color>
    <Color x:Key="AccentAI">#1D9E75</Color>
    <Color x:Key="TextPrimary">#E8E8F0</Color>
    <Color x:Key="TextSecondary">#A0A0B8</Color>
    <Color x:Key="TextMuted">#606078</Color>
    <Color x:Key="Border">#3A3A52</Color>
    <Color x:Key="Danger">#E24B4A</Color>
    <Color x:Key="Warning">#BA7517</Color>
    <Color x:Key="Success">#1D9E75</Color>
    <Color x:Key="TrackBlue">#378ADD</Color>
    <Color x:Key="TrackGreen">#1D9E75</Color>
    <Color x:Key="TrackOrange">#D85A30</Color>
    <Color x:Key="TrackPink">#D4537E</Color>
    <Color x:Key="TrackPurple">#7F77DD</Color>

    <SolidColorBrush x:Key="BrBgDark" Color="{StaticResource BgDark}"/>
    <SolidColorBrush x:Key="BrBgMid" Color="{StaticResource BgMid}"/>
    <SolidColorBrush x:Key="BrBgLight" Color="{StaticResource BgLight}"/>
    <SolidColorBrush x:Key="BrBgPanel" Color="{StaticResource BgPanel}"/>
    <SolidColorBrush x:Key="BrAccent" Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="BrAccentHover" Color="{StaticResource AccentHover}"/>
    <SolidColorBrush x:Key="BrAccentAI" Color="{StaticResource AccentAI}"/>
    <SolidColorBrush x:Key="BrText" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="BrTextSec" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="BrTextMuted" Color="{StaticResource TextMuted}"/>
    <SolidColorBrush x:Key="BrBorder" Color="{StaticResource Border}"/>
    <SolidColorBrush x:Key="BrDanger" Color="{StaticResource Danger}"/>
    <SolidColorBrush x:Key="BrWarning" Color="{StaticResource Warning}"/>
    <SolidColorBrush x:Key="BrSuccess" Color="{StaticResource Success}"/>
    <SolidColorBrush x:Key="BrTransparent" Color="Transparent"/>

    <!-- Button Style -->
    <Style x:Key="StdButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BrBgLight}"/>
        <Setter Property="Foreground" Value="{StaticResource BrText}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource BrBgMid}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BrAccent}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{StaticResource BrAccent}"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource BrAccentHover}"/>
                            <Setter Property="BorderThickness" Value="2"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- AI Button Style -->
    <Style x:Key="AIButton" TargetType="Button" BasedOn="{StaticResource StdButton}">
        <Setter Property="Background" Value="#1A3D30"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrAccentAI}"/>
        <Setter Property="Foreground" Value="#4ECFA0"/>
    </Style>

    <!-- Transport Button (big round) -->
    <Style x:Key="TransportButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BrBgLight}"/>
        <Setter Property="Foreground" Value="{StaticResource BrText}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="18">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource BrAccent}"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource BrAccentHover}"/>
                            <Setter Property="BorderThickness" Value="2"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Slider Style -->
    <Style TargetType="Slider">
        <Setter Property="Foreground" Value="{StaticResource BrAccent}"/>
        <Setter Property="Background" Value="{StaticResource BrBgMid}"/>
    </Style>

    <!-- TextBox Style -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource BrBgMid}"/>
        <Setter Property="Foreground" Value="{StaticResource BrText}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="CaretBrush" Value="{StaticResource BrText}"/>
    </Style>

    <!-- ComboBox Style -->
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource BrBgMid}"/>
        <Setter Property="Foreground" Value="{StaticResource BrText}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,4"/>
    </Style>

    <!-- Label Style -->
    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{StaticResource BrTextSec}"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <!-- CheckBox -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource BrText}"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <!-- ScrollBar slim -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="{StaticResource BrBgDark}"/>
        <Setter Property="Width" Value="8"/>
    </Style>

</ResourceDictionary>
