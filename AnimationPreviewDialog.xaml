<Window x:Class="UltraVideoEditor.AnimationPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pregled scenarija animacije" Height="500" Width="700"
        WindowStartupLocation="CenterOwner" Background="#2D2D2D">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="🎬 AI PROPOSED SCENARIO" FontSize="16" FontWeight="Bold" 
                   Foreground="#00E676" HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <TextBlock Text="You can change the image, duration and effect for each scene:" 
                   Foreground="White" Margin="0,0,0,10"/>

        <ListBox x:Name="lstScenes" Grid.Row="1" Background="#1E1E1E" Foreground="White"
                 AutomationProperties.Name="Scene list - you can change parameters">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#444" BorderThickness="0,0,0,1" Padding="5" Margin="0,0,0,5">
                        <StackPanel>
                            <TextBlock Text="{Binding Description}" Foreground="#00E676" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <TextBlock Text="Slika:" Foreground="White" Width="50" VerticalAlignment="Center"/>
                                <ComboBox ItemsSource="{Binding AvailableImages}" SelectedItem="{Binding ImageName}" 
                                          Width="150" Margin="0,0,10,0"
                                          AutomationProperties.Name="Izbor slike za scenu"/>
                                <TextBlock Text="Trajanje (s):" Foreground="White" Width="80" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding Duration}" Width="50" Margin="0,0,10,0"
                                         AutomationProperties.Name="Trajanje scene u sekundama"/>
                                <TextBlock Text="Efekat:" Foreground="White" Width="50" VerticalAlignment="Center"/>
                                <ComboBox ItemsSource="{Binding AvailableEffects}" SelectedItem="{Binding Effect}" 
                                          Width="100" AutomationProperties.Name="Izbor efekta za scenu"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15">
            <Button x:Name="btnConfirm" Content="✅ POTVRDI I NAPRAVI ANIMACIJU" Click="Confirm_Click" 
                    Width="220" Height="40" Background="#2E7D32" Foreground="White" FontWeight="Bold" Margin="0,0,10,0"/>
            <Button x:Name="btnCancel" Content="❌ CANCEL" Click="Cancel_Click" 
                    Width="100" Height="40" Background="#B71C1C" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>