<Window x:Class="UltraVideoEditor.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Precice na tastaturi" Height="620" Width="720"
        WindowStartupLocation="CenterOwner" Background="#1A1A2E"
        AutomationProperties.Name="Prozor sa svim precicama na tastaturi"
        KeyDown="Window_KeyDown">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="PRECICE NA TASTATURI" FontSize="22" FontWeight="Bold"
                   Foreground="#00E676" HorizontalAlignment="Center" Margin="0,0,0,5"
                   AutomationProperties.Name="Precice na tastaturi"/>
        <TextBlock Grid.Row="1" Text="Pritisnite Escape ili Alt+F4 za zatvaranje"
                   Foreground="#888888" HorizontalAlignment="Center" Margin="0,0,0,15"
                   FontSize="11"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      AutomationProperties.Name="Lista precica" Focusable="True">
            <StackPanel>

                <Border Background="#1E1E1E" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="FAJLOVI I PROJEKAT" FontSize="14" FontWeight="Bold"
                                   Foreground="#FF9800" Margin="0,0,0,8"/>
                        <TextBlock Text="Ctrl+N         Novi projekat" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Ctrl+O         Otvori projekat" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Ctrl+S         Sacuvaj projekat" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="F12            Sacuvaj kao..." Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Ctrl+E         Izvezi video (render)" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Alt+F4         Izlaz" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                    </StackPanel>
                </Border>

                <Border Background="#1E1E1E" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="UREDIVANJE" FontSize="14" FontWeight="Bold"
                                   Foreground="#FF9800" Margin="0,0,0,8"/>
                        <TextBlock Text="Ctrl+Z         Ponisti (Undo)" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Ctrl+Y         Ponovi (Redo)" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Ctrl+C         Kopiraj klip" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Ctrl+V         Zalepi klip" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Ctrl+X         Seci klip na poziciji" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Delete         Obrisi selektovani klip" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Ctrl+A         Selektuj sve" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Ctrl+D         Promeni trajanje klipa" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Ctrl+Alt+V     Podesi jacinu zvuka" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Ctrl+Left      Pomeri klip levo" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Ctrl+Right     Pomeri klip desno" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Ctrl+Up        Pomeri klip gore (traka)" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Ctrl+Down      Pomeri klip dole (traka)" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                    </StackPanel>
                </Border>

                <Border Background="#1E1E1E" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="DODAVANJE MEDIJA" FontSize="14" FontWeight="Bold"
                                   Foreground="#FF9800" Margin="0,0,0,8"/>
                        <TextBlock Text="Ctrl+I         Dodaj video ili sliku" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Ctrl+Shift+I   Dodaj audio fajl" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                    </StackPanel>
                </Border>

                <Border Background="#1E1E1E" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="REPRODUKCIJA" FontSize="14" FontWeight="Bold"
                                   Foreground="#FF9800" Margin="0,0,0,8"/>
                        <TextBlock Text="Ctrl+Space     Play / Pause" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Left/Right     Premotaj +/- 5 sekundi" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Home           Na pocetak" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="End            Na kraj" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                    </StackPanel>
                </Border>

                <Border Background="#1E1E1E" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="NAVIGACIJA TIMELINE" FontSize="14" FontWeight="Bold"
                                   Foreground="#FF9800" Margin="0,0,0,8"/>
                        <TextBlock Text="Strelica gore  Prethodni klip" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Strelica dole  Sledeci klip" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Page Up        5 klipova gore" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Page Down      5 klipova dole" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Ctrl+L         Fokus na timeline listu" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Ctrl++         Zoom uvecaj" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Ctrl+-         Zoom smanji" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Ctrl+0         Resetuj zoom" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                    </StackPanel>
                </Border>

                <Border Background="#1E1E1E" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="MARKERI" FontSize="14" FontWeight="Bold"
                                   Foreground="#FF9800" Margin="0,0,0,8"/>
                        <TextBlock Text="Ctrl+M         Dodaj marker" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Ctrl+Shift+N   Sledeci marker" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Ctrl+Shift+P   Prethodni marker" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Ctrl+Shift+X   Seci na svim markerima" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                    </StackPanel>
                </Border>

                <Border Background="#1E1E1E" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="ANIMACIJE I EFEKTI" FontSize="14" FontWeight="Bold"
                                   Foreground="#FF9800" Margin="0,0,0,8"/>
                        <TextBlock Text="Ctrl+K         Dodaj keyframe" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Ctrl+Shift+K   Ukloni keyframe" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Ctrl+Shift+E   Primeni efekte" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                    </StackPanel>
                </Border>

                <Border Background="#1E1E1E" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="PRISTUPACNOST (JAWS)" FontSize="14" FontWeight="Bold"
                                   Foreground="#FF9800" Margin="0,0,0,8"/>
                        <TextBlock Text="Ctrl+Shift+A   Ukljuci/iskljuci pristupacni mod" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Ctrl+Shift+L   Otvori log prozor" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="F1             Otvori ovu listu precica" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Desni klik     Kontekstni meni na klipu" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Enter/Space    Primeni tranziciju iz liste" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="F1 (tranzicija) Procitaj opis efekta (JAWS)" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                    </StackPanel>
                </Border>

                <Border Background="#1E1E1E" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="TABOVI" FontSize="14" FontWeight="Bold"
                                   Foreground="#FF9800" Margin="0,0,0,8"/>
                        <TextBlock Text="Ctrl+Tab       Sledeci tab" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                        <TextBlock Text="Ctrl+Shift+Tab Prethodni tab" Foreground="White" FontFamily="Consolas" Margin="5,2"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="3" Content="ZATVORI (Escape)" Click="CloseButton_Click"
                Height="36" Background="#2E7D32" Foreground="White"
                FontSize="13" FontWeight="Bold" Margin="0,15,0,0"
                AutomationProperties.Name="Zatvori prozor sa precicama"/>
    </Grid>
</Window>