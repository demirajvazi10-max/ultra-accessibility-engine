<Window x:Class="UltraVideoEditor.ExportOptions"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Opcije izvoza" Height="350" Width="450"
        WindowStartupLocation="CenterOwner" Background="#2D2D2D">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="🎬 Opcije izvoza" FontSize="20" FontWeight="Bold" 
                   Foreground="#00E676" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Format:" Foreground="White" Width="100" VerticalAlignment="Center"/>
            <ComboBox x:Name="cmbFormat" Width="200" SelectedIndex="0">
                <ComboBoxItem Content="MP4"/>
                <ComboBoxItem Content="WebM"/>
                <ComboBoxItem Content="AVI"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10">
            <TextBlock Text="Kvalitet:" Foreground="White" Width="100" VerticalAlignment="Center"/>
            <ComboBox x:Name="cmbQuality" Width="200" SelectedIndex="1">
                <ComboBoxItem Content="Nizak"/>
                <ComboBoxItem Content="Srednji"/>
                <ComboBoxItem Content="Visok"/>
            </ComboBox>
        </StackPanel>

        <CheckBox x:Name="chkAudioOnly" Grid.Row="3" Content="Izvezi samo audio" 
                  Foreground="White" Margin="0,15"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
            <Button x:Name="btnExport" Content="✅ IZVEZI" Click="Export_Click" Width="100" Height="35" 
                    Background="#2E7D32" Foreground="White" Margin="0,0,10,0"/>
            <Button x:Name="btnCancel" Content="❌ CANCEL" Click="Cancel_Click" Width="100" Height="35" 
                    Background="#B71C1C" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>