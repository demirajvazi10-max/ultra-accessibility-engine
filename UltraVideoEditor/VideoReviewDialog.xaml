<Window x:Class="UltraVideoEditor.VideoReviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Pregled Videa" Height="780" Width="860"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A2E" Foreground="White"
        AutomationProperties.Name="AI Pregled Videa — Qwen2-VL analizira video kao čovjek">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Naslov -->
        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,12">
            <TextBlock Text="AI PREGLED VIDEA" FontSize="22" FontWeight="Bold"
                       Foreground="#00E676" HorizontalAlignment="Center"/>
            <TextBlock Text="Qwen2-VL analizira video kadar po kadar — seckanja, kočenja, nelogičnosti, kvalitet"
                       Foreground="#888888" FontSize="11" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Odabir fajla -->
        <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="6" Padding="12" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtVideoPath" Background="#2D2D2D" Foreground="White"
                         BorderBrush="#444" Padding="6,4" FontSize="12" IsReadOnly="True"
                         Text="Izaberi video fajl za analizu..."
                         AutomationProperties.Name="Putanja video fajla za analizu"/>
                <Button Grid.Column="1" x:Name="btnBrowse" Content="📂 Otvori" Click="btnBrowse_Click"
                        Width="90" Height="30" Margin="8,0,0,0"
                        Background="#1565C0" Foreground="White" FontWeight="Bold"
                        AutomationProperties.Name="Otvori video fajl za analizu"/>
                <Button Grid.Column="2" x:Name="btnFromTimeline" Content="🎬 Iz Editora" Click="btnFromTimeline_Click"
                        Width="100" Height="30" Margin="6,0,0,0"
                        Background="#4A148C" Foreground="White" FontWeight="Bold"
                        AutomationProperties.Name="Koristi video fajl koji je trenutno u editoru"
                        ToolTip="Uzmi posljednji eksportovani video iz editora"/>
            </Grid>
        </Border>

        <!-- Opcije analize -->
        <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="6" Padding="12" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="INTERVAL ANALIZE" FontSize="11" FontWeight="Bold"
                               Foreground="#00E676" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Svake" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox x:Name="cmbInterval" Width="70" Height="26"
                                  Background="#2D2D2D" Foreground="White"
                                  AutomationProperties.Name="Interval uzorkovanja u sekundama">
                            <ComboBoxItem Tag="1">1 sek</ComboBoxItem>
                            <ComboBoxItem Tag="2" IsSelected="True">2 sek</ComboBoxItem>
                            <ComboBoxItem Tag="3">3 sek</ComboBoxItem>
                            <ComboBoxItem Tag="5">5 sek</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="ŠTA PROVJERITI" FontSize="11" FontWeight="Bold"
                               Foreground="#00E676" Margin="0,0,0,6"/>
                    <CheckBox x:Name="chkCuts" Content="Rezovi i seckanja" Foreground="White"
                              IsChecked="True" Margin="0,0,0,3"
                              AutomationProperties.Name="Provjeri nagle rezove i seckanja"/>
                    <CheckBox x:Name="chkQuality" Content="Kvalitet kadra" Foreground="White"
                              IsChecked="True" Margin="0,0,0,3"
                              AutomationProperties.Name="Provjeri kvalitet slike, oštrina, ekspozicija"/>
                    <CheckBox x:Name="chkLogic" Content="Logičnost toka" Foreground="White"
                              IsChecked="True"
                              AutomationProperties.Name="Provjeri logičnost prelaza između scena"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="DODATNO" FontSize="11" FontWeight="Bold"
                               Foreground="#00E676" Margin="0,0,0,6"/>
                    <CheckBox x:Name="chkRepeat" Content="Ponavljanje scena" Foreground="White"
                              IsChecked="True" Margin="0,0,0,3"
                              AutomationProperties.Name="Provjeri da li se iste scene ponavljaju"/>
                    <CheckBox x:Name="chkFreeze" Content="Zamrznuti kadrovi" Foreground="White"
                              IsChecked="True" Margin="0,0,0,3"
                              AutomationProperties.Name="Provjeri freeze frame greške"/>
                    <CheckBox x:Name="chkTeachMode" Content="🧠 Trening mode" Foreground="#FFD54F"
                              IsChecked="False"
                              AutomationProperties.Name="Trening mode — AI uči na osnovu tvog feedbacka"
                              ToolTip="AI bilježi tvoje komentare i uči što treba izbjegavati u budućim videjima"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status / progress -->
        <Border Grid.Row="3" Background="#1E1E1E" CornerRadius="6" Padding="10" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock x:Name="txtStatus" Text="Spreman. Izaberi video i pritisni ANALIZIRAJ."
                           Foreground="#FF9800" TextWrapping="Wrap" FontSize="12"
                           AutomationProperties.LiveSetting="Polite"
                           AutomationProperties.Name="Status analize"/>
                <ProgressBar x:Name="pbProgress" Height="10" Margin="0,8,0,4"
                             Minimum="0" Maximum="100" Value="0"
                             Foreground="#00E676" Background="#333"
                             AutomationProperties.Name="Napredak analize"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="txtFrameCounter" Text=""
                               Foreground="#888888" FontSize="10" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" x:Name="txtETA" Text=""
                               Foreground="#888888" FontSize="10" VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="2" x:Name="txtPct" Text=""
                               Foreground="#00E676" FontSize="11" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Izvještaj -->
        <Border Grid.Row="4" Background="#0D0D1A" CornerRadius="6" Padding="0" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Zaglavlje izvještaja sa sažetkom -->
                <Border Background="#1E1E1E" CornerRadius="6,6,0,0" Padding="12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="IZVJEŠTAJ ANALIZE" FontSize="11" FontWeight="Bold"
                                   Foreground="#00E676" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Border x:Name="badgeProblems" Background="#B71C1C" CornerRadius="10"
                                    Padding="8,2" Margin="0,0,6,0" Visibility="Collapsed">
                                <TextBlock x:Name="txtProblemCount" Text="0 problema"
                                           Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </Border>
                            <Border x:Name="badgeScore" Background="#1B5E20" CornerRadius="10"
                                    Padding="8,2" Visibility="Collapsed">
                                <TextBlock x:Name="txtScoreLabel" Text="Ocjena: —"
                                           Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Scrollable lista nalaza -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="lstFindings" Margin="8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,6" CornerRadius="6" Padding="10,8"
                                        Background="{Binding BackgroundColor}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Timestamp}"
                                                   Foreground="#FFD54F" FontWeight="Bold" FontSize="13"
                                                   VerticalAlignment="Center"
                                                   AutomationProperties.Name="{Binding TimestampAcc}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Icon}"
                                                   FontSize="16" VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="White" FontWeight="Bold" FontSize="12"/>
                                            <TextBlock Text="{Binding Description}"
                                                       Foreground="#BBBBBB" FontSize="11"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button Grid.Column="3" Content="▶ Idi"
                                                Tag="{Binding TimeSeconds}"
                                                Click="btnGoToTimestamp_Click"
                                                Width="55" Height="24"
                                                Background="#1565C0" Foreground="White"
                                                FontSize="10" Margin="8,0,0,0"
                                                AutomationProperties.Name="{Binding GoToAcc}"
                                                Visibility="{Binding CanNavigate}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Trening feedback (vidljiv samo u Trening modu) -->
        <Border Grid.Row="5" x:Name="borderTeach" Background="#1A1700" CornerRadius="6"
                Padding="10" Margin="0,0,0,8" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtTeachFeedback"
                         Background="#2D2A00" Foreground="#FFD54F" BorderBrush="#665500"
                         Padding="8,6" FontSize="12" TextWrapping="Wrap" Height="54"
                         AcceptsReturn="True"
                         Text="Upiši komentar o ovom videu (šta ti smeta, šta je dobro)..."
                         AutomationProperties.Name="Komentar za trening AI modela"/>
                <Button Grid.Column="1" Content="💾 Sačuvaj" Click="btnSaveFeedback_Click"
                        Width="80" Height="54" Margin="8,0,0,0"
                        Background="#F57F17" Foreground="White" FontWeight="Bold"
                        AutomationProperties.Name="Sačuvaj komentar za trening"/>
            </Grid>
        </Border>

        <!-- Dugmad -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
            <Button x:Name="btnAnalyze" Content="🔍 ANALIZIRAJ" Click="btnAnalyze_Click"
                    Width="140" Height="36" Margin="0,0,10,0"
                    Background="#2E7D32" Foreground="White" FontSize="13" FontWeight="Bold"
                    AutomationProperties.Name="Pokreni AI analizu videa"/>
            <Button x:Name="btnStop" Content="⏹ STOP" Click="btnStop_Click"
                    Width="90" Height="36" Margin="0,0,10,0"
                    Background="#B71C1C" Foreground="White" FontSize="13" FontWeight="Bold"
                    IsEnabled="False"
                    AutomationProperties.Name="Zaustavi analizu"/>
            <Button x:Name="btnExport" Content="📄 Izvezi izvještaj" Click="btnExport_Click"
                    Width="140" Height="36" Margin="0,0,10,0"
                    Background="#1565C0" Foreground="White" FontSize="12"
                    IsEnabled="False"
                    AutomationProperties.Name="Izvezi izvještaj kao tekstualni fajl"/>
            <Button x:Name="btnClose" Content="✖ Zatvori" Click="btnClose_Click"
                    Width="90" Height="36"
                    Background="#424242" Foreground="White" FontSize="12"
                    AutomationProperties.Name="Zatvori dijalog"/>
        </StackPanel>
    </Grid>
</Window>
