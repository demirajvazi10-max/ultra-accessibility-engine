<Window x:Class="UltraVideoEditor.AutoArrangeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🎬 Auto-rasporedi slike" Height="1000" Width="600"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1E1E1E"
        AutomationProperties.Name="Dialog for automatic image arrangement">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Naslov -->
        <TextBlock Text="🎬 AUTO-RASPOREDI SLIKE" FontSize="16" FontWeight="Bold"
                   Foreground="#00E676" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <!-- Info o audio -->
        <Border Grid.Row="1" Background="#2A2A2A" CornerRadius="4" Padding="8" Margin="0,0,0,10">
            <TextBlock x:Name="txtAudioInfo" Foreground="#88CCFF" TextWrapping="Wrap"/>
        </Border>

        <!-- Trajanje intro teksta -->
        <TextBlock Grid.Row="2" Text="Trajanje najavnog teksta (sekunde):" Foreground="White" Margin="0,5,0,3"/>
        <TextBox x:Name="txtIntroDuration" Grid.Row="3" Width="100" Height="30" Text="5" 
                 Background="#2D2D2D" Foreground="White" Margin="0,0,0,10"
                 AutomationProperties.Name="Trajanje najavnog teksta u sekundama"/>

        <!-- Trajanje outro teksta -->
        <TextBlock Grid.Row="4" Text="Trajanje odjavnog teksta (sekunde):" Foreground="White" Margin="0,5,0,3"/>
        <TextBox x:Name="txtOutroDuration" Grid.Row="5" Width="100" Height="30" Text="7" 
                 Background="#2D2D2D" Foreground="White" Margin="0,0,0,10"
                 AutomationProperties.Name="Trajanje odjavnog teksta u sekundama"/>

        <!-- Način odabira efekata -->
        <TextBlock Grid.Row="6" Text="Effect selection mode:" Foreground="White" Margin="0,5,0,3"/>
        <ComboBox x:Name="cmbEffectMode" Grid.Row="7" Height="30" Background="#2D2D2D" Foreground="White" Margin="0,0,0,10"
                  SelectionChanged="EffectMode_Changed"
                  AutomationProperties.Name="Effect mode selection">
            <ComboBoxItem Content="🎲 Automatic (cyclic)"/>
            <ComboBoxItem Content="🎲 Manual (define list)"/>
            <ComboBoxItem Content="🎲 Random"/>
        </ComboBox>

        <!-- Lista efekata (ručni unos) -->
        <TextBlock Grid.Row="8" Text="Lista efekata (odvoji zarezom):" Foreground="White" Margin="0,5,0,3"/>
        <TextBox x:Name="txtEffectSequence" Grid.Row="9" Height="60" TextWrapping="Wrap" 
                 Text="ZoomIn, SlideLeft, FadeIn, ZoomOut, SlideRight"
                 Background="#2D2D2D" Foreground="White" Margin="0,0,0,10" IsEnabled="False"
                 AutomationProperties.Name="Lista efekata odvojenih zarezom"/>

        <!-- Tekst na slici -->
        <Border Grid.Row="10" Background="#2A2A2A" CornerRadius="4" Padding="8" Margin="0,0,0,10">
            <StackPanel>
                <CheckBox x:Name="chkTextOnImage" Content="🎨 Dodaj tekst na svaku sliku" 
                          Foreground="White" IsChecked="False" Margin="0,0,0,5"
                          Checked="ChkTextOnImage_Checked" Unchecked="ChkTextOnImage_Checked"/>

                <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                    <TextBlock Text="Tekst:" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="txtOverlayText" Width="200" Height="25" Text=""
                             Background="#2D2D2D" Foreground="White" IsEnabled="False"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="20,5,0,0">
                    <CheckBox x:Name="chkUseCounter" Content="Dodaj broj slike (1,2,3...)" 
                              Foreground="White" IsChecked="False" IsEnabled="False"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="20,5,0,0">
                    <TextBlock Text="Font:" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="cmbOverlayFont" Width="120" Height="25" Background="#2D2D2D" Foreground="White" IsEnabled="False">
                        <ComboBoxItem Content="Arial" IsSelected="True"/>
                        <ComboBoxItem Content="Comic Sans MS"/>
                        <ComboBoxItem Content="Impact"/>
                    </ComboBox>
                    <TextBlock Text="Boja:" Foreground="White" VerticalAlignment="Center" Margin="10,0,10,0"/>
                    <ComboBox x:Name="cmbOverlayColor" Width="100" Height="25" Background="#2D2D2D" Foreground="White" IsEnabled="False">
                        <ComboBoxItem Content="⚪ White" Tag="#FFFFFF" IsSelected="True"/>
                        <ComboBoxItem Content="🟡 Yellow" Tag="#FFFF00"/>
                        <ComboBoxItem Content="⚫ Crna" Tag="#000000"/>
                    </ComboBox>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Logo -->
        <Border Grid.Row="11" Background="#2A2A2A" CornerRadius="4" Padding="8" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="🏷️ Logo kanala" Foreground="#00E676" FontWeight="Bold" Margin="0,0,0,8"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="Putanja do loga:" Foreground="White" Width="100" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtLogoPath" Width="250" Height="25" Background="#2D2D2D" Foreground="White" Padding="3"/>
                    <Button x:Name="btnBrowseLogo" Content="📂" Click="btnBrowseLogo_Click" Width="40" Height="25" Background="#FF9800" Foreground="White"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <CheckBox x:Name="chkShowLogo" Content="Show logo at start" 
                              Foreground="White" IsChecked="False" Margin="0,0,20,0"/>
                    <TextBlock Text="Trajanje loga (s):" Foreground="White" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtLogoDuration" Width="50" Height="25" Text="5" Background="#2D2D2D" Foreground="White" Margin="5,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Najavni i odjavni tekst -->
        <Border Grid.Row="12" Background="#2A2A2A" CornerRadius="4" Padding="8" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="📝 Tekstovi" Foreground="#00E676" FontWeight="Bold" Margin="0,0,0,8"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="Najavni tekst:" Foreground="White" Width="100" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtIntroText" Width="300" Height="25" Background="#2D2D2D" Foreground="White" Padding="3"
                             Text="🎵 New children's song"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="Odjavni tekst:" Foreground="White" Width="100" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtOutroText" Width="300" Height="25" Background="#2D2D2D" Foreground="White" Padding="3"
                             Text="👍 Thanks for watching! 🎵 Subscribe!"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Ime kanala:" Foreground="White" Width="100" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtChannelName" Width="250" Height="25" Background="#2D2D2D" Foreground="White" Padding="3"
                             Text="Kids World"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Rezolucija videa -->
        <Border Grid.Row="13" Background="#2A2A2A" CornerRadius="4" Padding="8" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="📹 Rezolucija videa:" Foreground="#00E676" FontWeight="Bold" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <ComboBox x:Name="cmbResolution" Width="150" Height="30" Background="#2D2D2D" Foreground="White">
                        <ComboBoxItem Content="📱 1280×720 (HD)" Tag="1280x720"/>
                        <ComboBoxItem Content="📺 1920×1080 (Full HD)" Tag="1920x1080" IsSelected="True"/>
                        <ComboBoxItem Content="🎬 2560×1440 (2K)" Tag="2560x1440"/>
                        <ComboBoxItem Content="🚀 3840×2160 (4K)" Tag="3840x2160"/>
                    </ComboBox>
                    <TextBlock Text=" (higher resolution = larger file)" Foreground="#888" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="10"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Animacija intro/outro -->
        <Border Grid.Row="14" Background="#2A2A2A" CornerRadius="4" Padding="8" Margin="0,0,0,10">
            <StackPanel>
                <CheckBox x:Name="chkAnimateIntro" Content="🎬 Animiraj najavni tekst" 
                          Foreground="White" IsChecked="True" Margin="0,0,0,5"/>
                <CheckBox x:Name="chkAnimateOutro" Content="🎬 Animiraj odjavni tekst" 
                          Foreground="White" IsChecked="True"/>
            </StackPanel>
        </Border>

        <!-- PROFESIONALNI EFEKTI -->
        <Border Grid.Row="15" Background="#2A2A2A" CornerRadius="4" Padding="8" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="🎬 Profesionalni efekti" Foreground="#00E676" FontWeight="Bold" Margin="0,0,0,8"/>

                <CheckBox x:Name="chkCrossfade" Content="↗ Smooth transitions (crossfade) between images" 
                          Foreground="White" IsChecked="True" Margin="0,0,0,5"
                          AutomationProperties.Name="Enable smooth transitions between images"/>

                <CheckBox x:Name="chkKenBurns" Content="🔍 Ken Burns efekat (lagani zoom na slikama)" 
                          Foreground="White" IsChecked="True" Margin="0,0,0,5"
                          AutomationProperties.Name="Enable Ken Burns zoom effect on images"/>

                <CheckBox x:Name="chkTransitionSounds" Content="🔊 Zvukovi pri promjeni scene (pop/whoosh)" 
                          Foreground="White" IsChecked="True" Margin="0,0,0,5"
                          AutomationProperties.Name="Add sound effects during image transitions"/>

                <CheckBox x:Name="chkAmbientSounds" Content="🌳 Ambijentalni zvukovi (ptice, vjetar, more, djeca)" 
                          Foreground="White" IsChecked="True" Margin="0,0,0,5"
                          AutomationProperties.Name="Add ambient sounds based on image content"/>
            </StackPanel>
        </Border>
        <!-- LOKALNA BIBLIOTEKA ZVUKOVA -->
        <Border Grid.Row="16" Background="#1A2A1A" CornerRadius="4" Padding="8" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="🔊 Lokalna biblioteka zvukova (Assets/Sounds/)" Foreground="#81C784" FontWeight="Bold" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock x:Name="txtLocalSoundsInfo" Text="Skeniranje..." Foreground="#AAAAAA" VerticalAlignment="Center" Width="350"/>
                    <Button x:Name="btnLocalSoundsInfo" Content="ℹ Info" Click="btnLocalSoundsInfo_Click"
                            Width="80" Height="28" Background="#388E3C" Foreground="White" Margin="5,0,0,0"
                            AutomationProperties.Name="Informacije o lokalnoj biblioteci zvukova"/>
                </StackPanel>
                <TextBlock Text="Postavi MP3/WAV fajlove u Assets/Sounds/ — AI automatski bira zvuk prema kontekstu"
                           Foreground="#888888" FontSize="9" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Dugmad -->
        <StackPanel Grid.Row="20" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button x:Name="btnApply" Content="🎬 PRIMIJENI" Click="Apply_Click"
                    Width="120" Height="35" Background="#2E7D32" Foreground="White"
                    FontSize="13" FontWeight="Bold" Margin="0,0,10,0"/>
            <Button x:Name="btnCancel" Content="❌ CANCEL" Click="Cancel_Click"
                    Width="100" Height="35" Background="#B71C1C" Foreground="White"
                    FontSize="13" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>